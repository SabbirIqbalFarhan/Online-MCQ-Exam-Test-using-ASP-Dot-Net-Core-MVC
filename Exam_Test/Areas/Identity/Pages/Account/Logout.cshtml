@page
@model LogoutModel
@{
    ViewData["Title"] = "Sign Out";
}

<style>
    .logout-wrap {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        background: linear-gradient(135deg, #f1f4fb 0%, #e8ecf8 100%);
    }

    .logout-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(26,34,54,0.12);
        border: 1px solid #e5e9f2;
        overflow: hidden;
        text-align: center;
    }

    .logout-header {
        background: #1a2236;
        padding: 36px 32px;
    }

    .logout-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        font-size: 22px;
        color: #fff;
        margin: 0 auto 16px;
    }

        .logout-icon.warning {
            background: #ef4444;
            box-shadow: 0 6px 20px rgba(239,68,68,0.4);
        }

        .logout-icon.success {
            background: #10b981;
            box-shadow: 0 6px 20px rgba(16,185,129,0.4);
        }

    .logout-header h2 {
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 4px;
    }

    .logout-header p {
        font-size: 13px;
        color: rgba(255,255,255,0.5);
        margin: 0;
    }

    .logout-body {
        padding: 32px;
    }

        .logout-body p {
            font-size: 14px;
            color: #64748b;
            line-height: 1.7;
            margin-bottom: 24px;
        }

    .btn-signout {
        width: 100%;
        background: #ef4444;
        border: none;
        padding: 12px;
        border-radius: 10px;
        color: #fff;
        font-weight: 700;
        font-size: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: 0.2s;
        box-shadow: 0 4px 14px rgba(239,68,68,0.3);
        margin-bottom: 10px;
    }

        .btn-signout:hover {
            background: #dc2626;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(239,68,68,0.4);
        }

    .btn-back {
        width: 100%;
        background: transparent;
        border: 1.5px solid #e2e8f0;
        padding: 11px;
        border-radius: 10px;
        color: #64748b;
        font-weight: 600;
        font-size: 13.5px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: 0.18s;
        text-decoration: none;
        display: block;
    }

        .btn-back:hover {
            border-color: #635bff;
            color: #635bff;
            background: rgba(99,91,255,0.04);
        }

    .btn-signin {
        width: 100%;
        background: #635bff;
        border: none;
        padding: 12px;
        border-radius: 10px;
        color: #fff;
        font-weight: 700;
        font-size: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: 0.2s;
        box-shadow: 0 4px 14px rgba(99,91,255,0.35);
        text-decoration: none;
        display: block;
        margin-bottom: 10px;
    }

        .btn-signin:hover {
            background: #4f46e5;
            color: #fff;
            transform: translateY(-1px);
        }

    .footer-note {
        padding: 16px;
        border-top: 1px solid #f1f5f9;
        font-size: 11.5px;
        color: #cbd5e1;
    }
</style>

<div class="logout-wrap">
    <div class="logout-card">

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="logout-header">
                <div class="logout-icon warning">
                    <i class="fa-solid fa-right-from-bracket"></i>
                </div>
                <h2>Sign Out?</h2>
                <p>You are currently signed in</p>
            </div>

            <div class="logout-body">
                <p>Are you sure you want to sign out? You will need to sign in again to access your account.</p>

                <form asp-area="Identity" asp-page="/Account/Logout"
                      asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                    <button type="submit" class="btn-signout">
                        <i class="fa-solid fa-right-from-bracket" style="margin-right:7px;"></i>
                        Yes, Sign Out
                    </button>
                </form>

                <a href="/" class="btn-back">
                    <i class="fa-solid fa-arrow-left" style="margin-right:6px;"></i>
                    Go Back
                </a>
            </div>
        }
        else
        {
            <div class="logout-header">
                <div class="logout-icon success">
                    <i class="fa-solid fa-check"></i>
                </div>
                <h2>Signed Out</h2>
                <p>Your session has been ended securely</p>
            </div>

            <div class="logout-body">
                <p>You have been successfully signed out. Thank you for using the Exam System.</p>

                <a asp-area="Identity" asp-page="/Account/Login" class="btn-signin">
                    <i class="fa-solid fa-right-to-bracket" style="margin-right:7px;"></i>
                    Sign Back In
                </a>

                <a href="/" class="btn-back">
                    <i class="fa-solid fa-house" style="margin-right:6px;"></i>
                    Back to Home
                </a>
            </div>
        }

        <div class="footer-note">© @DateTime.Now.Year Exam System</div>

    </div>
</div>