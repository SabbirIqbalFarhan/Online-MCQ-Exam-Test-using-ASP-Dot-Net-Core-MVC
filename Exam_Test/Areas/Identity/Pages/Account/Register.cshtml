@page
@model RegisterModel

@{
    ViewData["Title"] = "Register";
}

<style>
    .register-wrap {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        background: linear-gradient(135deg, #f1f4fb 0%, #e8ecf8 100%);
    }

    .register-card {
        width: 100%;
        max-width: 440px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(26,34,54,0.12);
        border: 1px solid #e5e9f2;
        overflow: hidden;
    }

    .register-header {
        background: #1a2236;
        padding: 32px;
        text-align: center;
    }

    .register-header-icon {
        width: 52px;
        height: 52px;
        background: #635bff;
        border-radius: 14px;
        display: grid;
        place-items: center;
        font-size: 22px;
        color: #fff;
        margin: 0 auto 14px;
        box-shadow: 0 6px 20px rgba(99,91,255,0.45);
    }

    .register-header h2 {
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 4px;
    }

    .register-header p {
        font-size: 13px;
        color: rgba(255,255,255,0.5);
        margin: 0;
    }

    .register-body {
        padding: 32px;
    }

    .field-label {
        font-size: 11.5px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 6px;
        display: block;
    }

    .field-wrap {
        position: relative;
        margin-bottom: 18px;
    }

        .field-wrap .f-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 13px;
        }

        .field-wrap .form-control {
            padding-left: 36px;
            height: 44px;
            border-radius: 10px;
            border: 1.5px solid #e2e8f0;
            font-size: 13.5px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #1e293b;
            transition: 0.18s;
            width: 100%;
            background: #f8fafc;
        }

            .field-wrap .form-control:focus {
                outline: none;
                border-color: #635bff;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(99,91,255,0.1);
            }

    .btn-register {
        width: 100%;
        background: #635bff;
        border: none;
        padding: 12px;
        border-radius: 10px;
        color: #fff;
        font-weight: 700;
        font-size: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: 0.2s;
        box-shadow: 0 4px 14px rgba(99,91,255,0.35);
        letter-spacing: 0.3px;
    }

        .btn-register:hover {
            background: #4f46e5;
            box-shadow: 0 6px 20px rgba(99,91,255,0.45);
            transform: translateY(-1px);
        }

    .register-footer {
        text-align: center;
        padding: 20px 32px 28px;
        border-top: 1px solid #f1f5f9;
    }

        .register-footer a {
            font-size: 13px;
            color: #635bff;
            text-decoration: none;
            font-weight: 600;
            transition: 0.18s;
        }

            .register-footer a:hover {
                color: #4f46e5;
                text-decoration: underline;
            }

    .external-section {
        padding: 0 32px 28px;
    }

    .divider-text {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 12px;
        color: #94a3b8;
        margin-bottom: 14px;
    }

        .divider-text::before,
        .divider-text::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }

    .btn-external {
        width: 100%;
        padding: 10px;
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        background: #f8fafc;
        color: #1e293b;
        font-size: 13.5px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: 0.18s;
        margin-bottom: 8px;
    }

        .btn-external:hover {
            border-color: #635bff;
            background: #fff;
            color: #635bff;
        }

    .text-danger {
        font-size: 12px;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="register-wrap">
    <div class="register-card">

        <div class="register-header">
            <div class="register-header-icon">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            <h2>Create Account</h2>
            <p>Register to access the Exam System</p>
        </div>

        <div class="register-body">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div>
                    <label class="field-label">Email Address</label>
                    <div class="field-wrap">
                        <i class="fa-solid fa-envelope f-icon"></i>
                        <input asp-for="Input.Email" class="form-control"
                               autocomplete="username" placeholder="you@example.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div>
                    <label class="field-label">Password</label>
                    <div class="field-wrap">
                        <i class="fa-solid fa-lock f-icon"></i>
                        <input asp-for="Input.Password" class="form-control"
                               type="password" autocomplete="new-password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div>
                    <label class="field-label">Confirm Password</label>
                    <div class="field-wrap">
                        <i class="fa-solid fa-lock f-icon"></i>
                        <input asp-for="Input.ConfirmPassword" class="form-control"
                               type="password" autocomplete="new-password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn-register">
                    <i class="fa-solid fa-user-plus" style="margin-right:7px;"></i>
                    Create Account
                </button>

            </form>
        </div>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="external-section">
                <div class="divider-text">or continue with</div>
                <form id="external-account" asp-page="./ExternalLogin"
                      asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn-external"
                                name="provider" value="@provider.Name">
                            Continue with @provider.DisplayName
                        </button>
                    }
                </form>
            </div>
        }

        <div class="register-footer">
            <a asp-area="Identity" asp-page="/Account/Login">
                <i class="fa-solid fa-right-to-bracket" style="margin-right:5px;"></i>
                Already have an account? Sign In
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}