@page
@using Exam_Test.Areas.Identity.Pages.Account
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<style>
    .login-wrap {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        background: linear-gradient(135deg, #f1f4fb 0%, #e8ecf8 100%);
    }

    .login-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(26,34,54,0.12);
        border: 1px solid #e5e9f2;
        overflow: hidden;
    }

    .login-header {
        background: #1a2236;
        padding: 32px;
        text-align: center;
    }

    .login-header-icon {
        width: 52px;
        height: 52px;
        background: #635bff;
        border-radius: 14px;
        display: grid;
        place-items: center;
        font-size: 22px;
        color: #fff;
        margin: 0 auto 14px;
        box-shadow: 0 6px 20px rgba(99,91,255,0.45);
    }

    .login-header h2 {
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 4px;
    }

    .login-header p {
        font-size: 13px;
        color: rgba(255,255,255,0.5);
        margin: 0;
    }

    .login-body {
        padding: 32px;
    }

    .field-label {
        font-size: 11.5px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        margin-bottom: 6px;
        display: block;
    }

    .field-wrap {
        position: relative;
        margin-bottom: 18px;
    }

        .field-wrap .f-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 13px;
        }

        .field-wrap .form-control {
            padding-left: 36px;
            height: 44px;
            border-radius: 10px;
            border: 1.5px solid #e2e8f0;
            font-size: 13.5px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #1e293b;
            transition: 0.18s;
            width: 100%;
            background: #f8fafc;
        }

            .field-wrap .form-control:focus {
                outline: none;
                border-color: #635bff;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(99,91,255,0.1);
            }

    .remember-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 22px;
    }

        .remember-row input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: #635bff;
            cursor: pointer;
        }

        .remember-row label {
            font-size: 13px;
            color: #64748b;
            cursor: pointer;
            margin: 0;
        }

    .btn-login {
        width: 100%;
        background: #635bff;
        border: none;
        padding: 12px;
        border-radius: 10px;
        color: #fff;
        font-weight: 700;
        font-size: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: 0.2s;
        box-shadow: 0 4px 14px rgba(99,91,255,0.35);
        letter-spacing: 0.3px;
    }

        .btn-login:hover {
            background: #4f46e5;
            box-shadow: 0 6px 20px rgba(99,91,255,0.45);
            transform: translateY(-1px);
        }

    .login-footer {
        text-align: center;
        padding: 20px 32px 28px;
        border-top: 1px solid #f1f5f9;
    }

        .login-footer a {
            font-size: 13px;
            color: #635bff;
            text-decoration: none;
            font-weight: 600;
            transition: 0.18s;
        }

            .login-footer a:hover {
                color: #4f46e5;
                text-decoration: underline;
            }

    .text-danger {
        font-size: 12px;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="login-wrap">
    <div class="login-card">

        <div class="login-header">
            <div class="login-header-icon">
                <i class="fa-solid fa-graduation-cap"></i>
            </div>
            <h2>Exam System</h2>
            <p>Sign in to your account to continue</p>
        </div>

        <div class="login-body">
            <form id="account" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div>
                    <label class="field-label">Email Address</label>
                    <div class="field-wrap">
                        <i class="fa-solid fa-envelope f-icon"></i>
                        <input asp-for="Input.Email" class="form-control"
                               placeholder="you@example.com" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div>
                    <label class="field-label">Password</label>
                    <div class="field-wrap">
                        <i class="fa-solid fa-lock f-icon"></i>
                        <input asp-for="Input.Password" class="form-control"
                               type="password" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="remember-row">
                    <input asp-for="Input.RememberMe" type="checkbox" id="rememberMe" />
                    <label for="rememberMe">Remember me</label>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fa-solid fa-right-to-bracket" style="margin-right:7px;"></i>
                    Sign In
                </button>

            </form>
        </div>

        <div class="login-footer">
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                <i class="fa-solid fa-user-plus" style="margin-right:5px;"></i>
                Don't have an account? Register
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}