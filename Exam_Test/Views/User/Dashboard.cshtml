@{
    ViewData["Title"] = "User Dashboard";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f4f6ff;
        color: #111827;
    }

    .page {
        max-width: 900px;
        margin: auto;
        padding: 40px 20px;
    }

    .header {
        margin-bottom: 20px;
    }

        .header h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

        .header p {
            font-size: 13px;
            color: #6b7280;
            margin-top: 5px;
        }

    /* GRID */
    .grid {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    /* CARD */
    .card {
        flex: 1 1 250px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.04);
        transition: 0.2s;
    }

        .card:hover {
            transform: translateY(-3px);
        }

    .label {
        font-size: 11px;
        font-weight: 600;
        color: #4f46e5;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .card h3 {
        margin: 10px 0 6px;
        font-size: 18px;
    }

    .card p {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 14px;
    }

    /* BUTTON */
    .btn {
        display: inline-block;
        padding: 10px 14px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        background: #4f46e5;
        color: #fff;
        transition: 0.2s;
    }

        .btn:hover {
            background: #3730a3;
        }

</style>

<div class="page">

    <div class="header">
        <h2>🎓 User Dashboard</h2>
        <p>Select a module to start your exam</p>
    </div>

    <div class="grid">

        <div class="card">
            <div class="label">Module</div>
            <h3>Module 1</h3>
            <p>Basic level questions for practice and learning.</p>
            <a class="btn" href="/User/Module/1">Start Exam</a>
        </div>

        <div class="card">
            <div class="label">Module</div>
            <h3>Module 2</h3>
            <p>Intermediate level questions for skill improvement.</p>
            <a class="btn" href="/User/Module/2">Start Exam</a>
        </div>

        <div class="card">
            <div class="label">Module</div>
            <h3>Module 3</h3>
            <p>Advanced level questions for final evaluation.</p>
            <a class="btn" href="/User/Module/3">Start Exam</a>
        </div>

    </div>

</div>