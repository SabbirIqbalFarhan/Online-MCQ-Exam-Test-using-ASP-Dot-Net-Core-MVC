<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>

<style>
    body {
        background: #f6f8fc;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
    }

    /* NAVBAR */
    .custom-navbar {
        background: #fff;
        border-bottom: 1px solid #e5e7eb;
        padding: 10px 20px;
    }

    .logout-btn {
        background: #4f46e5;
        border: none;
        border-radius: 6px;
        padding: 6px 14px;
        color: white !important;
        transition: 0.2s;
    }

        .logout-btn:hover {
            background: #4338ca;
            color: white !important;
        }

    /* 🔥 UNIFIED BUTTON STYLE */
    .nav-btn {
        display: inline-block;
        padding: 9px 14px;
        margin-right: 8px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        background: #4f46e5;
        color: #fff !important;
        transition: 0.2s ease;
    }

        .nav-btn:hover {
            background: #3730a3;
            color: #fff !important;
        }

    /* layout */
    .nav-left {
        display: flex;
        align-items: center;
    }

</style>

<body>

    <nav class="custom-navbar navbar">

        <div class="container-fluid d-flex justify-content-between align-items-center">

            <!-- LEFT SIDE BUTTONS -->
            <div class="nav-left">

                <a class="nav-btn" asp-controller="Home" asp-action="Index">
                    Home
                </a>

                <a class="nav-btn" asp-controller="Home" asp-action="Privacy">
                    Privacy
                </a>

            </div>

            <!-- RIGHT SIDE (LoginPartial already styled similarly) -->
            <div>
                <partial name="_LoginPartial" />
            </div>

        </div>

    </nav>

    <div class="container" style="padding:20px;">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>