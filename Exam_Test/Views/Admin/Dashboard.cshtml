@{
    ViewData["Title"] = "Admin Panel";
}

<style>
    .admin-wrap {
        display: flex;
        min-height: calc(100vh - 60px);
        background: #f0f2f8;
    }

    /* SIDEBAR */
    .sidebar {
        width: 230px;
        background: #1e2a3a;
        color: #fff;
        display: flex;
        flex-direction: column;
        padding: 24px 0;
        flex-shrink: 0;
    }

    .sidebar-brand {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        padding: 0 20px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        margin-bottom: 16px;
        letter-spacing: 0.5px;
    }

    .sidebar-brand span {
        color: #6366f1;
    }

    .sidebar-label {
        font-size: 10px;
        font-weight: 600;
        color: rgba(255,255,255,0.35);
        text-transform: uppercase;
        letter-spacing: 1.2px;
        padding: 0 20px;
        margin: 10px 0 6px;
    }

    .sidebar a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        border-left: 3px solid transparent;
        transition: 0.2s;
    }

    .sidebar a:hover, .sidebar a.active {
        background: rgba(99,102,241,0.12);
        color: #fff;
        border-left-color: #6366f1;
    }

    .sidebar a .icon {
        font-size: 15px;
        width: 20px;
        text-align: center;
    }

    /* MAIN CONTENT */
    .main {
        flex: 1;
        padding: 28px;
        overflow-y: auto;
    }

    .page-title {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .page-sub {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 24px;
    }

    /* STAT CARDS */
    .stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: #fff;
        border-radius: 14px;
        padding: 20px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }

    .stat-card .label {
        font-size: 11px;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
    }

    .stat-card .number {
        font-size: 32px;
        font-weight: 700;
        color: #111827;
        line-height: 1;
    }

    .stat-card .icon {
        font-size: 22px;
        margin-bottom: 10px;
    }

    .stat-card.pending .number { color: #f59e0b; }
    .stat-card.users .number  { color: #6366f1; }
    .stat-card.q .number      { color: #10b981; }
    .stat-card.results .number{ color: #3b82f6; }

    /* QUICK ACTIONS */
    .section-title {
        font-size: 14px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 14px;
    }

    .actions-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 28px;
    }

    .action-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 20px;
        text-decoration: none;
        color: #111827;
        transition: 0.2s;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .action-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        color: #111827;
    }

    .action-card .a-icon {
        font-size: 24px;
        margin-bottom: 4px;
    }

    .action-card .a-title {
        font-size: 14px;
        font-weight: 700;
    }

    .action-card .a-desc {
        font-size: 12px;
        color: #6b7280;
    }

    /* RECENT RESULTS TABLE */
    .table-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
    }

    .table-card table {
        width: 100%;
        border-collapse: collapse;
    }

    .table-card thead {
        background: #1e2a3a;
        color: #fff;
    }

    .table-card th, .table-card td {
        padding: 12px 16px;
        font-size: 13px;
        text-align: left;
    }

    .table-card tbody tr {
        border-bottom: 1px solid #f3f4f6;
        transition: 0.2s;
    }

    .table-card tbody tr:hover {
        background: #f8f9ff;
    }

    .badge-green {
        background: #dcfce7;
        color: #166534;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-red {
        background: #fee2e2;
        color: #991b1b;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-yellow {
        background: #fef9c3;
        color: #854d0e;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
    }
</style>

<div class="admin-wrap">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-brand">TVDE <span>Admin</span></div>

        <div class="sidebar-label">Main</div>
        <a href="/Admin/Dashboard" class="active">
            <span class="icon">📊</span> Dashboard
        </a>

        <div class="sidebar-label">Users</div>
        <a href="/AdminUser">
            <span class="icon">👥</span> All Users
        </a>

        <div class="sidebar-label">Questions</div>
        <a href="/Admin/Questions?moduleId=1">
            <span class="icon">📝</span> Module 1
        </a>
        <a href="/Admin/Questions?moduleId=2">
            <span class="icon">📝</span> Module 2
        </a>
        <a href="/Admin/Questions?moduleId=3">
            <span class="icon">📝</span> Module 3
        </a>

        <div class="sidebar-label">Reports</div>
        <a href="/AdminResult">
            <span class="icon">📈</span> Exam Results
        </a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <div class="page-title">Dashboard</div>
        <div class="page-sub">Welcome back, Admin. Here's what's happening.</div>

        <!-- STATS -->
        <div class="stats">
            <div class="stat-card users">
                <div class="icon">👥</div>
                <div class="label">Total Users</div>
                <div class="number">@ViewBag.TotalUsers</div>
            </div>
            <div class="stat-card q">
                <div class="icon">📝</div>
                <div class="label">Total Questions</div>
                <div class="number">@ViewBag.TotalQuestions</div>
            </div>
            <div class="stat-card results">
                <div class="icon">📊</div>
                <div class="label">Total Results</div>
                <div class="number">@ViewBag.TotalResults</div>
            </div>
            <div class="stat-card pending">
                <div class="icon">⏳</div>
                <div class="label">Pending Requests</div>
                <div class="number">@ViewBag.PendingRequests</div>
            </div>
        </div>

        <!-- QUICK ACTIONS -->
        <div class="section-title">Quick Actions</div>
        <div class="actions-grid">
            <a class="action-card" href="/AdminUser">
                <div class="a-icon">👥</div>
                <div class="a-title">Manage Users</div>
                <div class="a-desc">Grant or revoke exam permissions</div>
            </a>
            <a class="action-card" href="/Admin/Questions?moduleId=1">
                <div class="a-icon">📝</div>
                <div class="a-title">Manage Questions</div>
                <div class="a-desc">Add, edit or delete exam questions</div>
            </a>
            <a class="action-card" href="/AdminResult">
                <div class="a-icon">📈</div>
                <div class="a-title">View Reports</div>
                <div class="a-desc">Check student exam performance</div>
            </a>
        </div>

        <!-- RECENT RESULTS -->
        <div class="section-title">Recent Exam Results</div>
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Module</th>
                        <th>Correct</th>
                        <th>Wrong</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in ViewBag.RecentResults)
                    {
                        <tr>
                            <td>@r.UserId</td>
                            <td>Module @r.ModuleId</td>
                            <td><span class="badge-green">@r.Correct</span></td>
                            <td><span class="badge-red">@r.Wrong</span></td>
                            <td>@r.ExamDate.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                    @if (((IEnumerable<dynamic>)ViewBag.RecentResults).Count() == 0)
                    {
                        <tr>
                            <td colspan="5" style="text-align:center; color:#9ca3af; padding:30px;">
                                No exam results yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>