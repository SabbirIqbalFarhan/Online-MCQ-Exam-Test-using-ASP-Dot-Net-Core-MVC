@model Exam_Test.Models.Question

@{
    ViewData["Title"] = "Edit Question";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f4f6ff;
        color: #111827;
    }

    .page {
        max-width: 800px;
        margin: auto;
        padding: 40px 20px;
    }

    .header {
        margin-bottom: 18px;
    }

        .header h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

        .header p {
            font-size: 13px;
            color: #6b7280;
            margin-top: 5px;
        }

    .badge {
        display: inline-block;
        background: #eef2ff;
        color: #4f46e5;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 500;
        margin-top: 8px;
    }

    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.04);
    }

    .section-title {
        font-size: 11px;
        font-weight: 600;
        color: #4f46e5;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
    }

    input[type="text"],
    input[type="file"] {
        width: 100%;
        padding: 11px 12px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        font-size: 13px;
        outline: none;
        transition: 0.2s;
        background: #fff;
        margin-bottom: 10px;
    }

    input:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
    }

    .question-box {
        background: #f8f9ff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 14px;
        margin-bottom: 16px;
    }

    .options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .hint {
        font-size: 12px;
        color: #6b7280;
        margin-top: 4px;
    }

    .btn {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #4f46e5, #6366f1);
        color: white;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 16px;
        transition: 0.2s;
    }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(79,70,229,0.25);
        }

</style>

<div class="page">

    <div class="header">
        <h2>✏️ Edit Question</h2>
        <p>Update existing question details</p>
        <div class="badge">Module @Model.ModuleId</div>
    </div>

    <div class="card">

        <div class="section-title">Question Details</div>

        <form method="post" enctype="multipart/form-data">

            <input type="hidden" name="Id" value="@Model.Id" />
            <input type="hidden" name="ModuleId" value="@Model.ModuleId" />

            <!-- QUESTION -->
            <div class="question-box">

                <input type="text"
                       name="QuestionText"
                       value="@Model.QuestionText"
                       placeholder="Enter question..." />

                <input type="file" name="imageFile" />

                <div class="hint">Upload new image if you want to replace existing one</div>
            </div>

            <!-- OPTIONS -->
            <div class="section-title">Answer Options</div>

            <div class="options">

                <input type="text" name="OptionA" value="@Model.OptionA" placeholder="Option A" />
                <input type="text" name="OptionB" value="@Model.OptionB" placeholder="Option B" />
                <input type="text" name="OptionC" value="@Model.OptionC" placeholder="Option C" />
                <input type="text" name="OptionD" value="@Model.OptionD" placeholder="Option D" />

            </div>

            <!-- CORRECT -->
            <div style="margin-top:14px;">
                <input type="text"
                       name="CorrectAnswer"
                       value="@Model.CorrectAnswer"
                       placeholder="Correct Answer (A / B / C / D)" />

                <div class="hint">Select correct option letter</div>
            </div>

            <button type="submit" class="btn">
                Update Question
            </button>

        </form>

    </div>

</div>