@model Exam_Test.Models.Question

@{
    ViewData["Title"] = "Add Question";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f4f6ff;
        color: #111827;
    }

    .page {
        max-width: 800px;
        margin: auto;
        padding: 40px 20px;
    }

    /* HEADER */
    .header {
        margin-bottom: 20px;
    }

        .header h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

        .header p {
            font-size: 13px;
            color: #6b7280;
            margin-top: 5px;
        }

    /* CARD */
    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.04);
    }

    .section-title {
        font-size: 11px;
        font-weight: 600;
        color: #4f46e5;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
    }

    /* INPUTS */
    input[type="text"],
    input[type="file"] {
        width: 100%;
        padding: 11px 12px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        font-size: 13px;
        outline: none;
        transition: 0.2s;
        background: #fff;
    }

    input:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
    }

    .form-group {
        margin-bottom: 14px;
    }

    /* QUESTION BOX */
    .question-box {
        background: #f8f9ff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 14px;
        margin-bottom: 16px;
    }

    /* OPTIONS GRID */
    .options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 10px;
    }

    /* CORRECT ANSWER HIGHLIGHT */
    .hint {
        font-size: 12px;
        color: #6b7280;
        margin-top: 4px;
    }

    /* BUTTON */
    .btn {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #4f46e5, #6366f1);
        color: white;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 16px;
        transition: 0.2s;
    }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(79,70,229,0.25);
        }

    /* MODULE BADGE */
    .badge {
        display: inline-block;
        background: #eef2ff;
        color: #4f46e5;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 500;
        margin-top: 6px;
    }

</style>

<div class="page">

    <div class="header">
        <h2>📝 Add New Question</h2>
        <p>Module based question creation panel</p>
        <div class="badge">Module @ViewBag.ModuleId</div>
    </div>

    <div class="card">

        <div class="section-title">Question Details</div>

        <form method="post" enctype="multipart/form-data">

            <input type="hidden" name="ModuleId" value="@ViewBag.ModuleId" />

            <!-- QUESTION -->
            <div class="question-box">
                <div class="form-group">
                    <input type="text" name="QuestionText" placeholder="Enter your question..." />
                </div>

                <div class="form-group">
                    <input type="file" name="imageFile" />
                    <div class="hint">Optional: Add image for better clarity</div>
                </div>
            </div>

            <!-- OPTIONS -->
            <div class="section-title">Answer Options</div>

            <div class="options">
                <input type="text" name="OptionA" placeholder="Option A" />
                <input type="text" name="OptionB" placeholder="Option B" />
                <input type="text" name="OptionC" placeholder="Option C" />
                <input type="text" name="OptionD" placeholder="Option D" />
            </div>

            <!-- CORRECT -->
            <div class="form-group" style="margin-top:16px;">
                <input type="text" name="CorrectAnswer" placeholder="Correct Answer (A / B / C / D)" />
            </div>

            <button type="submit" class="btn">
                Save Question
            </button>

        </form>

    </div>

</div>