@{
    ViewData["Title"] = "Add Question";
}

<style>
    .page {
        max-width: 800px;
        margin: auto;
        padding: 40px 20px;
    }

    .header {
        margin-bottom: 20px;
    }

        .header h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

        .header p {
            font-size: 13px;
            color: #6b7280;
            margin-top: 5px;
        }

    .badge {
        display: inline-block;
        background: #eef2ff;
        color: #4f46e5;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 500;
        margin-top: 6px;
    }

    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.04);
    }

    .section-title {
        font-size: 11px;
        font-weight: 600;
        color: #4f46e5;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
    }

    input[type="text"],
    input[type="file"] {
        width: 100%;
        padding: 11px 12px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        font-size: 13px;
        outline: none;
        transition: 0.2s;
        background: #fff;
        box-sizing: border-box;
    }

    input:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
    }

    .form-group {
        margin-bottom: 14px;
    }

    .question-box {
        background: #f8f9ff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 14px;
        margin-bottom: 16px;
    }

    .options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 14px;
    }

    .hint {
        font-size: 12px;
        color: #6b7280;
        margin-top: 4px;
    }

    .btn {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: none;
        background: #4f46e5;
        color: white;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 16px;
        transition: 0.2s;
    }

        .btn:hover {
            background: #3730a3;
        }
</style>

<div class="page">

    <div class="header">
        <h2>📝 Add New Question</h2>
        <p>Module based question creation panel</p>
        <div class="badge">Module @ViewBag.ModuleId</div>
    </div>

    <div class="card">

        <form method="post" action="/Admin/AddQuestion" enctype="multipart/form-data">

            <input type="hidden" name="ModuleId" value="@ViewBag.ModuleId" />

            <div class="section-title">Question</div>

            <div class="question-box">
                <div class="form-group">
                    <input type="text" name="QuestionText"
                           placeholder="Enter question text... (optional if image is used)" />
                </div>
                <div class="form-group">
                    <input type="file" name="imageFile" accept="image/*" />
                    <div class="hint">Optional: upload an image as the question</div>
                </div>
            </div>

            <div class="section-title">Answer Options</div>

            <div class="options">
                <input type="text" name="OptionA" placeholder="Option A" />
                <input type="text" name="OptionB" placeholder="Option B" />
                <input type="text" name="OptionC" placeholder="Option C" />
                <input type="text" name="OptionD" placeholder="Option D" />
            </div>

            <div class="section-title">Correct Answer</div>

            <div class="form-group">
                <input type="text" name="CorrectAnswer"
                       placeholder="Enter correct option letter: A / B / C / D" />
            </div>

            <button type="submit" class="btn">Save Question</button>

        </form>

    </div>

</div>