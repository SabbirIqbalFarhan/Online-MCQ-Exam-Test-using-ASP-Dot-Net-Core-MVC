@{
    ViewData["Title"] = "Add Question";
}

<style>
    .page-wrap {
        max-width: 720px;
        margin: 0 auto;
        padding: 36px 20px 80px;
    }

    .page-header-block {
        background: #1a2236;
        border-radius: 20px;
        padding: 28px 32px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .page-header-icon {
        width: 52px;
        height: 52px;
        background: #635bff;
        border-radius: 14px;
        display: grid;
        place-items: center;
        font-size: 22px;
        color: #fff;
        flex-shrink: 0;
        box-shadow: 0 6px 20px rgba(99,91,255,0.45);
    }

    .page-header-block h2 {
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 4px;
    }

    .page-header-block p {
        font-size: 13px;
        color: rgba(255,255,255,0.5);
        margin: 0 0 10px;
    }

    .module-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(99,91,255,0.25);
        border: 1px solid rgba(99,91,255,0.4);
        color: #c4c0ff;
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 11.5px;
        font-weight: 700;
        letter-spacing: 0.3px;
    }

    .form-card {
        background: #fff;
        border: 1px solid #e5e9f2;
        border-radius: 20px;
        padding: 28px 32px;
        box-shadow: 0 4px 20px rgba(26,34,54,0.06);
    }

    .field-section-label {
        font-size: 11px;
        font-weight: 700;
        color: #635bff;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        margin-bottom: 12px;
        margin-top: 4px;
    }

    .question-box {
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 22px;
    }

    .field-wrap {
        margin-bottom: 12px;
    }

        .field-wrap input[type="text"],
        .field-wrap input[type="file"] {
            width: 100%;
            padding: 11px 14px;
            border-radius: 10px;
            border: 1.5px solid #e2e8f0;
            font-size: 13.5px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #1e293b;
            background: #fff;
            outline: none;
            transition: 0.18s;
            box-sizing: border-box;
        }

            .field-wrap input[type="text"]:focus {
                border-color: #635bff;
                box-shadow: 0 0 0 3px rgba(99,91,255,0.1);
                background: #fff;
            }

    .hint-text {
        font-size: 12px;
        color: #94a3b8;
        margin-top: 5px;
    }

    .options-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 22px;
    }

    .opt-wrap {
        position: relative;
    }

    .opt-label {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 11px;
        font-weight: 800;
        color: #635bff;
        pointer-events: none;
    }

    .opt-wrap input[type="text"] {
        width: 100%;
        padding: 11px 14px 11px 30px;
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        font-size: 13.5px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: #1e293b;
        background: #f8fafc;
        outline: none;
        transition: 0.18s;
        box-sizing: border-box;
    }

        .opt-wrap input[type="text"]:focus {
            border-color: #635bff;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(99,91,255,0.1);
        }

    .correct-wrap {
        position: relative;
        margin-bottom: 24px;
    }

        .correct-wrap input[type="text"] {
            width: 100%;
            padding: 11px 14px;
            border-radius: 10px;
            border: 1.5px solid #e2e8f0;
            font-size: 13.5px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #1e293b;
            background: #f8fafc;
            outline: none;
            transition: 0.18s;
            box-sizing: border-box;
        }

            .correct-wrap input[type="text"]:focus {
                border-color: #10b981;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(16,185,129,0.1);
            }

    .btn-save {
        width: 100%;
        background: #635bff;
        border: none;
        padding: 13px;
        border-radius: 12px;
        color: #fff;
        font-weight: 700;
        font-size: 14px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        transition: 0.2s;
        box-shadow: 0 4px 14px rgba(99,91,255,0.35);
        letter-spacing: 0.3px;
    }

        .btn-save:hover {
            background: #4f46e5;
            box-shadow: 0 6px 20px rgba(99,91,255,0.45);
            transform: translateY(-1px);
        }

    .divider {
        border: none;
        border-top: 1.5px solid #f1f5f9;
        margin: 20px 0;
    }
</style>

<div class="page-wrap">

    <div class="page-header-block">
        <div class="page-header-icon">
            <i class="fa-solid fa-plus"></i>
        </div>
        <div>
            <h2>Add New Question</h2>
            <p>Module-based question creation panel</p>
            <span class="module-pill">
                <i class="fa-solid fa-layer-group"></i>
                Module @ViewBag.ModuleId
            </span>
        </div>
    </div>

    <div class="form-card">
        <form method="post" action="/Admin/AddQuestion" enctype="multipart/form-data">

            <input type="hidden" name="ModuleId" value="@ViewBag.ModuleId" />

            <div class="field-section-label">
                <i class="fa-solid fa-circle-question" style="margin-right:5px;"></i>
                Question
            </div>

            <div class="question-box">
                <div class="field-wrap">
                    <input type="text" name="QuestionText"
                           placeholder="Enter question text... (optional if image is used)" />
                </div>
                <div class="field-wrap">
                    <input type="file" name="imageFile" accept="image/*" />
                    <div class="hint-text">
                        <i class="fa-solid fa-image" style="margin-right:4px;"></i>
                        Optional: upload an image as the question
                    </div>
                </div>
            </div>

            <div class="field-section-label">
                <i class="fa-solid fa-list-ul" style="margin-right:5px;"></i>
                Answer Options
            </div>

            <div class="options-grid">
                <div class="opt-wrap">
                    <span class="opt-label">A</span>
                    <input type="text" name="OptionA" placeholder="Option A" />
                </div>
                <div class="opt-wrap">
                    <span class="opt-label">B</span>
                    <input type="text" name="OptionB" placeholder="Option B" />
                </div>
                <div class="opt-wrap">
                    <span class="opt-label">C</span>
                    <input type="text" name="OptionC" placeholder="Option C" />
                </div>
            </div>

            <hr class="divider" />

            <div class="field-section-label">
                <i class="fa-solid fa-circle-check" style="margin-right:5px;color:#10b981;"></i>
                Correct Answer
            </div>

            <div class="correct-wrap">
                <input type="text" name="CorrectAnswer"
                       placeholder="Enter correct option letter: A / B / C" />
                <div class="hint-text">Type the letter of the correct option above</div>
            </div>

            <button type="submit" class="btn-save">
                <i class="fa-solid fa-floppy-disk" style="margin-right:8px;"></i>
                Save Question
            </button>

        </form>
    </div>

</div>