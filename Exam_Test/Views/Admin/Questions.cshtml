@model List<Exam_Test.Models.Question>

@{
    ViewData["Title"] = "Questions";
    int count = ViewBag.QuestionCount;
    bool canAdd = ViewBag.CanAdd;
}

<style>
    .admin-wrap {
        display: flex;
        min-height: calc(100vh - 60px);
        background: #f1f4fb;
    }

    .dash-sidebar {
        width: 230px;
        background: #1a2236;
        flex-shrink: 0;
        padding: 24px 0;
        display: flex;
        flex-direction: column;
    }

    .nav-section-label {
        font-size: 9.5px;
        font-weight: 700;
        color: rgba(240,244,255,0.35);
        text-transform: uppercase;
        letter-spacing: 1.4px;
        padding: 14px 20px 6px;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 11px;
        padding: 9px 20px;
        color: rgba(240,244,255,0.62);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        border-left: 3px solid transparent;
        transition: all 0.18s;
    }

    .sidebar-link:hover {
        color: #fff;
        background: rgba(99,91,255,0.1);
        border-left-color: rgba(99,91,255,0.5);
    }

    .sidebar-link.active {
        color: #fff;
        background: rgba(99,91,255,0.15);
        border-left-color: #635bff;
    }

    .sidebar-link .s-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        font-size: 14px;
        flex-shrink: 0;
        background: rgba(255,255,255,0.06);
        transition: 0.18s;
    }

    .sidebar-link:hover .s-icon,
    .sidebar-link.active .s-icon {
        background: rgba(99,91,255,0.25);
    }

    .dash-main {
        flex: 1;
        padding: 28px;
        overflow-y: auto;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
        gap: 16px;
        flex-wrap: wrap;
    }

    .topbar h2 {
        font-size: 22px;
        font-weight: 800;
        color: #1a2236;
        margin: 0 0 8px;
    }

    .meta-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .module-badge {
        background: rgba(99,91,255,0.1);
        color: #635bff;
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .count-badge {
        background: #dcfce7;
        color: #166534;
        padding: 4px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
    }

    .count-badge.full {
        background: #fee2e2;
        color: #991b1b;
    }

    .progress-wrap {
        background: #e2e8f0;
        border-radius: 999px;
        height: 7px;
        width: 150px;
        overflow: hidden;
    }

    .progress-fill {
        height: 7px;
        border-radius: 999px;
        background: #635bff;
        transition: width 0.4s;
    }

    .progress-fill.full { background: #ef4444; }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 18px;
        border-radius: 10px;
        background: #635bff;
        color: #fff !important;
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: 0.2s;
        box-shadow: 0 4px 12px rgba(99,91,255,0.3);
        white-space: nowrap;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .btn-add:hover {
        background: #4f46e5;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(99,91,255,0.4);
    }

    .btn-add.disabled {
        background: #cbd5e1;
        color: #94a3b8 !important;
        pointer-events: none;
        box-shadow: none;
    }

    .limit-alert {
        background: #fee2e2;
        border: 1px solid #fecaca;
        color: #991b1b;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .questions-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 12px;
    }

    .q-card {
        background: #fff;
        border: 1px solid #e5e9f2;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(26,34,54,0.04);
        transition: 0.2s;
        display: flex;
        flex-direction: column;
    }

    .q-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 24px rgba(26,34,54,0.1);
        border-color: #d4d0ff;
    }

    .q-card-top {
        padding: 12px;
        flex: 1;
    }

    .serial-row {
        display: flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 10px;
    }

    .serial-num {
        width: 24px;
        height: 24px;
        background: #635bff;
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10.5px;
        font-weight: 800;
        flex-shrink: 0;
    }

    .ans-pill {
        background: #dcfce7;
        color: #166534;
        border-radius: 999px;
        padding: 2px 8px;
        font-size: 10px;
        font-weight: 700;
    }

    .q-img img {
        width: 100%;
        height: auto;
        max-height: 110px;
        object-fit: contain;
        border-radius: 8px;
        margin-bottom: 8px;
        border: 1px solid #e5e9f2;
        background: #f8fafc;
    }

    .q-text {
        font-size: 11.5px;
        font-weight: 600;
        color: #1a2236;
        line-height: 1.5;
        margin-bottom: 8px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .opts-list {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .opt-item {
        font-size: 10.5px;
        padding: 4px 8px;
        border-radius: 7px;
        background: #f8fafc;
        border: 1px solid #e5e9f2;
        color: #374151;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .opt-item.correct {
        background: #dcfce7;
        border-color: #bbf7d0;
        color: #166534;
        font-weight: 700;
    }

    .q-card-actions {
        display: flex;
        border-top: 1px solid #e5e9f2;
    }

    .btn-action {
        flex: 1;
        padding: 9px 4px;
        font-size: 11.5px;
        font-weight: 700;
        text-decoration: none;
        text-align: center;
        transition: 0.18s;
        color: #fff;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .btn-edit-q  { background: #06b6d4; }
    .btn-edit-q:hover  { background: #0891b2; color: #fff; }

    .btn-delete-q { background: #ef4444; }
    .btn-delete-q:hover { background: #dc2626; color: #fff; }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #94a3b8;
        font-size: 14px;
        background: #fff;
        border: 1px solid #e5e9f2;
        border-radius: 16px;
    }

    .empty-state p {
        margin-top: 8px;
        font-size: 13px;
    }
</style>

<div class="admin-wrap">

    <div class="dash-sidebar">
        <div class="nav-section-label">Main</div>
        <a class="sidebar-link" href="/Admin/Dashboard">
            <span class="s-icon">📊</span><span>Dashboard</span>
        </a>

        <div class="nav-section-label">Users</div>
        <a class="sidebar-link" href="/AdminUser">
            <span class="s-icon">👥</span><span>All Users</span>
        </a>

        <div class="nav-section-label">Questions</div>
        <a class="sidebar-link @(ViewBag.ModuleId == 1 ? "active" : "")" href="/Admin/Questions?moduleId=1">
            <span class="s-icon">📝</span><span>Module 1</span>
        </a>
        <a class="sidebar-link @(ViewBag.ModuleId == 2 ? "active" : "")" href="/Admin/Questions?moduleId=2">
            <span class="s-icon">📝</span><span>Module 2</span>
        </a>
        <a class="sidebar-link @(ViewBag.ModuleId == 3 ? "active" : "")" href="/Admin/Questions?moduleId=3">
            <span class="s-icon">📝</span><span>Module 3</span>
        </a>

        <div class="nav-section-label">Sessions</div>
        <a class="sidebar-link" href="/AdminSession">
            <span class="s-icon">🕐</span><span>Exam Sessions</span>
        
    </div>

    <div class="dash-main">

        <div class="topbar">
            <div>
                <h2>Questions</h2>
                <div class="meta-row">
                    <span class="module-badge">
                        <i class="fa-solid fa-layer-group" style="margin-right:4px;"></i>
                        Module @ViewBag.ModuleId
                    </span>
                    <span class="count-badge @(count >= 30 ? "full" : "")">
                        @count / 30
                    </span>
                    <div class="progress-wrap">
                        <div class="progress-fill @(count >= 30 ? "full" : "")"
                             style="width:@(count * 100 / 30)%"></div>
                    </div>
                </div>
            </div>

            <a class="btn-add @(!canAdd ? "disabled" : "")"
               href="/Admin/AddQuestion?moduleId=@ViewBag.ModuleId">
                <i class="fa-solid fa-plus"></i>
                Add Question
            </a>
        </div>

        @if (count >= 30)
        {
            <div class="limit-alert">
                <i class="fa-solid fa-triangle-exclamation"></i>
                Maximum 30 questions reached. Delete one to add a new question.
            </div>
        }

        @if (Model != null && Model.Count > 0)
        {
            <div class="questions-grid">
                @{ int serial = 1; }
                @foreach (var q in Model)
                {
                    <div class="q-card">
                        <div class="q-card-top">
                            <div class="serial-row">
                                <div class="serial-num">@serial</div>
                                <span class="ans-pill">Ans: @q.CorrectAnswer</span>
                            </div>

                            @if (!string.IsNullOrEmpty(q.ImagePath))
                            {
                                <div class="q-img">
                                    <img src="~/images/@q.ImagePath" />
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(q.QuestionText))
                            {
                                <div class="q-text">@q.QuestionText</div>
                            }

                            <div class="opts-list">
                                <div class="opt-item @(q.CorrectAnswer == "A" ? "correct" : "")">A. @q.OptionA</div>
                                <div class="opt-item @(q.CorrectAnswer == "B" ? "correct" : "")">B. @q.OptionB</div>
                                <div class="opt-item @(q.CorrectAnswer == "C" ? "correct" : "")">C. @q.OptionC</div>
                            </div>
                        </div>

                        <div class="q-card-actions">
                            <a class="btn-action btn-edit-q" href="/Admin/EditQuestion/@q.Id">
                                <i class="fa-solid fa-pen" style="margin-right:3px;"></i>Edit
                            </a>
                            <a class="btn-action btn-delete-q" href="/Admin/DeleteQuestion/@q.Id">
                                <i class="fa-solid fa-trash" style="margin-right:3px;"></i>Delete
                            </a>
                        </div>
                    </div>
                    serial++;
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div style="font-size:36px;margin-bottom:8px;">📭</div>
                <strong>No questions yet</strong>
                <p>No questions have been added to this module.</p>
            </div>
        }

    </div>
</div>