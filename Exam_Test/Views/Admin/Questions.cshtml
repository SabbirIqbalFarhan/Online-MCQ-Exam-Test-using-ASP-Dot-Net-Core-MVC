@model List<Exam_Test.Models.Question>

@{
    ViewData["Title"] = "Questions";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f4f6ff;
        color: #111827;
    }

    .page {
        max-width: 1000px;
        margin: auto;
        padding: 40px 20px;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
    }

        .header h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

    .badge {
        background: #eef2ff;
        color: #4f46e5;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 500;
    }

    /* ADD BUTTON */
    .add-btn {
        display: inline-block;
        padding: 9px 14px;
        border-radius: 10px;
        background: #4f46e5;
        color: #fff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: 0.2s;
    }

        .add-btn:hover {
            background: #3730a3;
        }

    /* GRID */
    .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }

    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: 0.2s;
    }

        .card:hover {
            box-shadow: 0 8px 20px rgba(0,0,0,0.06);
            transform: translateY(-2px);
        }

    .q-text {
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 4px;
    }

    .answer {
        font-size: 12px;
        color: #6b7280;
    }

    /* ACTION BUTTONS */
    .actions {
        display: flex;
        gap: 8px;
    }

    .btn {
        padding: 7px 10px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        text-decoration: none;
        color: #fff;
        transition: 0.2s;
    }

    .edit {
        background: #4f46e5;
    }

        .edit:hover {
            background: #3730a3;
        }

    .delete {
        background: #ef4444;
    }

        .delete:hover {
            background: #b91c1c;
        }

    /* EMPTY STATE */
    .empty {
        text-align: center;
        padding: 40px;
        color: #6b7280;
    }

</style>

<div class="page">

    <div class="header">
        <div>
            <h2>Questions</h2>
            <span class="badge">Module @ViewBag.ModuleId</span>
        </div>

        <a class="add-btn" href="/Admin/AddQuestion?moduleId=@ViewBag.ModuleId">
            + Add Question
        </a>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="grid">

            @foreach (var q in Model)
            {
                <div class="card">

                    <div>
                        <div class="q-text">@q.QuestionText</div>
                        <div class="answer">Correct Answer: @q.CorrectAnswer</div>
                    </div>

                    <div class="actions">
                        <a class="btn edit" href="/Admin/EditQuestion/@q.Id">Edit</a>
                        <a class="btn delete" href="/Admin/DeleteQuestion/@q.Id">Delete</a>
                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="empty">
            No questions found in this module.
        </div>
    }

</div>