@model List<Exam_Test.Models.Question>

@{
    ViewData["Title"] = "Questions";
    int count = ViewBag.QuestionCount;
    bool canAdd = ViewBag.CanAdd;
}

<style>
    .admin-wrap {
        display: flex;
        min-height: calc(100vh - 60px);
        background: #f0f2f8;
    }

    .sidebar {
        width: 230px;
        background: #1e2a3a;
        color: #fff;
        display: flex;
        flex-direction: column;
        padding: 24px 0;
        flex-shrink: 0;
    }

    .sidebar-brand {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        padding: 0 20px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        margin-bottom: 16px;
    }

    .sidebar-brand span { color: #6366f1; }

    .sidebar-label {
        font-size: 10px;
        font-weight: 600;
        color: rgba(255,255,255,0.35);
        text-transform: uppercase;
        letter-spacing: 1.2px;
        padding: 0 20px;
        margin: 10px 0 6px;
    }

    .sidebar a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        border-left: 3px solid transparent;
        transition: 0.2s;
    }

    .sidebar a:hover, .sidebar a.active {
        background: rgba(99,102,241,0.12);
        color: #fff;
        border-left-color: #6366f1;
    }

    .sidebar a .icon { font-size: 15px; width: 20px; text-align: center; }

    .main {
        flex: 1;
        padding: 28px;
        overflow-y: auto;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .topbar h2 {
        font-size: 20px;
        font-weight: 700;
        margin: 0;
        color: #111827;
    }

    .meta {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 6px;
        flex-wrap: wrap;
    }

    .module-badge {
        background: #eef2ff;
        color: #4f46e5;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
    }

    .count-badge {
        background: #f0fdf4;
        color: #166534;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
    }

    .count-badge.full {
        background: #fef2f2;
        color: #991b1b;
    }

    .progress-wrap {
        background: #e5e7eb;
        border-radius: 999px;
        height: 7px;
        width: 160px;
        overflow: hidden;
    }

    .progress-fill {
        height: 7px;
        border-radius: 999px;
        background: #4f46e5;
    }

    .progress-fill.full { background: #ef4444; }

    .add-btn {
        display: inline-block;
        padding: 9px 16px;
        border-radius: 10px;
        background: #4f46e5;
        color: #fff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: 0.2s;
        white-space: nowrap;
    }

    .add-btn:hover { background: #3730a3; color: #fff; }

    .add-btn.disabled {
        background: #9ca3af;
        pointer-events: none;
    }

    .limit-msg {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 13px;
        margin-bottom: 14px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
    }

    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        transition: 0.2s;
        display: flex;
        flex-direction: column;
    }

    .card:hover {
        box-shadow: 0 6px 18px rgba(0,0,0,0.09);
        transform: translateY(-2px);
    }

    .card-top { padding: 10px; flex: 1; }

    .serial-row {
        display: flex;
        align-items: center;
        gap: 7px;
        margin-bottom: 8px;
    }

    .serial {
        width: 24px;
        height: 24px;
        background: #4f46e5;
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .correct-pill {
        background: #dcfce7;
        color: #166534;
        border-radius: 999px;
        padding: 2px 8px;
        font-size: 10px;
        font-weight: 600;
    }

    .q-image img {
        width: 100%;
        height: auto;
        max-height: 120px;
        object-fit: contain;
        border-radius: 8px;
        margin-bottom: 7px;
        border: 1px solid #e5e7eb;
        background: #f9fafb;
    }

    .q-text {
        font-size: 11px;
        font-weight: 600;
        color: #111827;
        line-height: 1.4;
        margin-bottom: 7px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .options-list {
        display: flex;
        flex-direction: column;
        gap: 3px;
        margin-bottom: 4px;
    }

    .opt {
        font-size: 10px;
        padding: 3px 7px;
        border-radius: 6px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        color: #374151;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .opt.correct {
        background: #dcfce7;
        border-color: #bbf7d0;
        color: #166534;
        font-weight: 600;
    }

    .card-actions {
        display: flex;
        border-top: 1px solid #e5e7eb;
    }

    .btn {
        flex: 1;
        padding: 8px 4px;
        font-size: 11px;
        font-weight: 600;
        text-decoration: none;
        text-align: center;
        transition: 0.2s;
        color: #fff;
    }

    .btn-edit { background: #0891b2; }
    .btn-edit:hover { background: #0e7490; color: #fff; }

    .btn-delete { background: #f97316; }
    .btn-delete:hover { background: #ea580c; color: #fff; }

    .empty {
        text-align: center;
        padding: 60px;
        color: #9ca3af;
        font-size: 14px;
    }
</style>

<div class="admin-wrap">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-brand">TVDE <span>Admin</span></div>

        <div class="sidebar-label">Main</div>
        <a href="/Admin/Dashboard">
            <span class="icon">📊</span> Dashboard
        </a>

        <div class="sidebar-label">Users</div>
        <a href="/AdminUser">
            <span class="icon">👥</span> All Users
        </a>

        <div class="sidebar-label">Questions</div>
        <a href="/Admin/Questions?moduleId=1" class="@(ViewBag.ModuleId == 1 ? "active" : "")">
            <span class="icon">📝</span> Module 1
        </a>
        <a href="/Admin/Questions?moduleId=2" class="@(ViewBag.ModuleId == 2 ? "active" : "")">
            <span class="icon">📝</span> Module 2
        </a>
        <a href="/Admin/Questions?moduleId=3" class="@(ViewBag.ModuleId == 3 ? "active" : "")">
            <span class="icon">📝</span> Module 3
        </a>

        <div class="sidebar-label">Sessions</div>
        <a href="/AdminSession">
            <span class="icon">🕐</span> Exam Sessions
        </a>

        <div class="sidebar-label">Reports</div>
        <a href="/AdminResult">
            <span class="icon">📈</span> Exam Results
        </a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <div class="topbar">
            <div>
                <h2>Questions</h2>
                <div class="meta">
                    <span class="module-badge">Module @ViewBag.ModuleId</span>
                    <span class="count-badge @(count >= 30 ? "full" : "")">
                        @count / 30
                    </span>
                    <div class="progress-wrap">
                        <div class="progress-fill @(count >= 30 ? "full" : "")"
                             style="width: @(count * 100 / 30)%"></div>
                    </div>
                </div>
            </div>

            <a class="add-btn @(!canAdd ? "disabled" : "")"
               href="/Admin/AddQuestion?moduleId=@ViewBag.ModuleId">
                + Add Question
            </a>
        </div>

        @if (count >= 30)
        {
            <div class="limit-msg">
                ⚠️ Maximum 30 questions reached. Delete one to add a new question.
            </div>
        }

        @if (Model != null && Model.Count > 0)
        {
            <div class="grid">
                @{int serial = 1;}
                @foreach (var q in Model)
                {
                    <div class="card">
                        <div class="card-top">
                            <div class="serial-row">
                                <div class="serial">@serial</div>
                                <span class="correct-pill">Ans: @q.CorrectAnswer</span>
                            </div>

                            @if (!string.IsNullOrEmpty(q.ImagePath))
                            {
                                <div class="q-image">
                                    <img src="~/images/@q.ImagePath" />
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(q.QuestionText))
                            {
                                <div class="q-text">@q.QuestionText</div>
                            }

                            <div class="options-list">
                                <div class="opt @(q.CorrectAnswer == "A" ? "correct" : "")">A. @q.OptionA</div>
                                <div class="opt @(q.CorrectAnswer == "B" ? "correct" : "")">B. @q.OptionB</div>
                                <div class="opt @(q.CorrectAnswer == "C" ? "correct" : "")">C. @q.OptionC</div>
                                <div class="opt @(q.CorrectAnswer == "D" ? "correct" : "")">D. @q.OptionD</div>
                            </div>
                        </div>

                        <div class="card-actions">
                            <a class="btn btn-edit" href="/Admin/EditQuestion/@q.Id">Edit</a>
                            <a class="btn btn-delete" href="/Admin/DeleteQuestion/@q.Id">Delete</a>
                        </div>
                    </div>
                    serial++;
                }
            </div>
        }
        else
        {
            <div class="empty">📭 No questions added yet for this module.</div>
        }

    </div>
</div>