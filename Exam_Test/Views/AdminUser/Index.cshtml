@model List<Microsoft.AspNetCore.Identity.IdentityUser>

@{
    ViewData["Title"] = "Users";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f4f6ff;
        color: #111827;
    }

    .page {
        max-width: 1000px;
        margin: auto;
        padding: 40px 20px;
    }

    .header {
        margin-bottom: 20px;
    }

        .header h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

        .header p {
            font-size: 13px;
            color: #6b7280;
            margin-top: 5px;
        }

    /* TABLE CARD */
    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0,0,0,0.04);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: #4f46e5;
        color: #fff;
    }

    th, td {
        padding: 14px 16px;
        text-align: left;
        font-size: 13px;
    }

    tbody tr {
        border-bottom: 1px solid #e5e7eb;
        transition: 0.2s;
    }

        tbody tr:hover {
            background: #f8f9ff;
        }

    /* BUTTON */
    .btn {
        display: inline-block;
        padding: 7px 12px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        text-decoration: none;
        background: #4f46e5;
        color: #fff;
        transition: 0.2s;
    }

        .btn:hover {
            background: #3730a3;
        }

</style>

<div class="page">

    <div class="header">
        <h2>👥 Users List</h2>
        <p>Manage all registered users</p>
    </div>

    <div class="card">

        <table>

            <thead>
                <tr>
                    <th>Email</th>
                    <th>Username</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>@user.UserName</td>
                        <td>
                            <a class="btn" href="/AdminUser/Details/@user.Id">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>