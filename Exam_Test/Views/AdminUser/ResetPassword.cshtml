@{
    ViewData["Title"] = "Reset Password";
}

<style>
    .page {
        max-width: 600px;
        margin: auto;
        padding: 40px 20px;
    }

    .header {
        margin-bottom: 20px;
    }

        .header h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

        .header p {
            font-size: 13px;
            color: #6b7280;
            margin-top: 5px;
        }

    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.04);
    }

    .info-row {
        background: #f8f9ff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 13px;
        margin-bottom: 18px;
        color: #374151;
    }

    input[type="password"] {
        width: 100%;
        padding: 11px 12px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        font-size: 13px;
        outline: none;
        transition: 0.2s;
        margin-bottom: 14px;
        box-sizing: border-box;
    }

        input[type="password"]:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
        }

    .btn {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: none;
        background: #4f46e5;
        color: white;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn:hover {
            background: #3730a3;
        }

    .alert-success {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #bbf7d0;
        border-radius: 10px;
        padding: 12px 14px;
        font-size: 13px;
        margin-bottom: 14px;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
        border-radius: 10px;
        padding: 12px 14px;
        font-size: 13px;
        margin-bottom: 14px;
    }

    .back-link {
        display: inline-block;
        margin-top: 14px;
        font-size: 13px;
        color: #4f46e5;
        text-decoration: none;
    }

        .back-link:hover {
            text-decoration: underline;
        }
</style>

<div class="page">

    <div class="header">
        <h2>🔑 Reset Password</h2>
        <p>Set a new password for this user</p>
    </div>

    <div class="card">

        <div class="info-row">
            📧 <strong>@ViewBag.UserEmail</strong>
        </div>

        @if (ViewBag.Message != null)
        {
            if (ViewBag.Success == true)
            {
                <div class="alert-success">✅ @ViewBag.Message</div>
            }
            else
            {
                <div class="alert-danger">❌ @ViewBag.Message</div>
            }
        }

        <form method="post">
            <input type="hidden" name="id" value="@ViewBag.UserId" />
            <input type="password" name="newPassword" placeholder="Enter new password..." />
            <button type="submit" class="btn">Reset Password</button>
        </form>

        <a class="back-link" href="/AdminUser/Details/@ViewBag.UserId">← Back to User Details</a>

    </div>

</div>