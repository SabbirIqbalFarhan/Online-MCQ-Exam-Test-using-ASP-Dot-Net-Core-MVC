@model Microsoft.AspNetCore.Identity.IdentityUser

@{
    ViewData["Title"] = "User Details";
    var profile = ViewBag.Profile as Exam_Test.Models.UserProfile;
    var permission = ViewBag.Permission as Exam_Test.Models.ExamPermission;
    bool isPermitted = permission != null && permission.IsPermitted;
}

<style>
    .admin-wrap {
    display: flex;
    min-height: calc(100vh - 60px);
    background: #f1f4fb;
    margin: -28px; /* cancel page-wrapper padding */
}
.dash-main {
    flex: 1;
    padding: 28px;
    overflow-y: auto;
}
.dash-sidebar {
    width: 230px;
    background: #1a2236;
    flex-shrink: 0;
    padding: 60px 0 24px; /* was 24px 0 */
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}
.stats-grid { grid-template-columns: repeat(2, 1fr); }
.actions-grid { grid-template-columns: 1fr; }
.modules-grid { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
.summary-grid { grid-template-columns: repeat(2, 1fr); }

    .nav-section-label {
        font-size: 9.5px;
        font-weight: 700;
        color: rgba(240,244,255,0.35);
        text-transform: uppercase;
        letter-spacing: 1.4px;
        padding: 14px 20px 6px;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 11px;
        padding: 9px 20px;
        color: rgba(240,244,255,0.62);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        border-left: 3px solid transparent;
        transition: all 0.18s;
    }

    .sidebar-link:hover {
        color: #fff;
        background: rgba(99,91,255,0.1);
        border-left-color: rgba(99,91,255,0.5);
    }

    .sidebar-link.active {
        color: #fff;
        background: rgba(99,91,255,0.15);
        border-left-color: #635bff;
    }

    .sidebar-link .s-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        font-size: 14px;
        flex-shrink: 0;
        background: rgba(255,255,255,0.06);
        transition: 0.18s;
    }

    .sidebar-link:hover .s-icon,
    .sidebar-link.active .s-icon {
        background: rgba(99,91,255,0.25);
    }


    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 16px;
        border-radius: 10px;
        background: #1a2236;
        color: rgba(255,255,255,0.8) !important;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 22px;
        transition: 0.18s;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .btn-back:hover {
        background: #243050;
        color: #fff !important;
    }

    .user-hero {
        background: #1a2236;
        border-radius: 20px;
        padding: 28px 32px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .user-avatar-lg {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: #635bff;
        display: grid;
        place-items: center;
        font-size: 22px;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
        box-shadow: 0 6px 20px rgba(99,91,255,0.45);
    }

    .user-hero h2 {
        font-size: 18px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 4px;
    }

    .user-hero p {
        font-size: 13px;
        color: rgba(255,255,255,0.5);
        margin: 0;
    }

    .detail-card {
        background: #fff;
        border: 1px solid #e5e9f2;
        border-radius: 16px;
        overflow: hidden;
        max-width: 640px;
        box-shadow: 0 2px 8px rgba(26,34,54,0.04);
        margin-bottom: 22px;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 20px;
        border-bottom: 1px solid #f1f5f9;
        font-size: 13px;
    }

    .detail-row:last-child {
        border-bottom: none;
    }

    .detail-label {
        font-size: 11.5px;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .detail-value {
        font-size: 13.5px;
        font-weight: 600;
        color: #1a2236;
        text-align: right;
    }

    .badge-permitted {
        background: #dcfce7;
        color: #166534;
        padding: 5px 12px;
        border-radius: 999px;
        font-size: 11.5px;
        font-weight: 700;
    }

    .badge-not-permitted {
        background: #fee2e2;
        color: #991b1b;
        padding: 5px 12px;
        border-radius: 999px;
        font-size: 11.5px;
        font-weight: 700;
    }

    .section-title {
        font-size: 13px;
        font-weight: 700;
        color: #1a2236;
        margin-bottom: 14px;
    }

    .actions-grid {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        max-width: 640px;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 18px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        color: #fff;
        transition: 0.2s;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .btn-purple { background: #635bff; box-shadow: 0 4px 12px rgba(99,91,255,0.3); }
    .btn-purple:hover { background: #4f46e5; color: #fff; transform: translateY(-1px); }

    .btn-green  { background: #10b981; box-shadow: 0 4px 12px rgba(16,185,129,0.3); }
    .btn-green:hover  { background: #059669; color: #fff; transform: translateY(-1px); }

    .btn-red    { background: #ef4444; box-shadow: 0 4px 12px rgba(239,68,68,0.25); }
    .btn-red:hover    { background: #dc2626; color: #fff; transform: translateY(-1px); }

    .btn-dark   { background: #1a2236; box-shadow: 0 4px 12px rgba(26,34,54,0.2); }
    .btn-dark:hover   { background: #243050; color: #fff; transform: translateY(-1px); }
</style>

<div class="admin-wrap">

    <div class="dash-sidebar">
        <div class="nav-section-label">Main</div>
        <a class="sidebar-link" href="/Admin/Dashboard">
            <span class="s-icon">📊</span><span>Dashboard</span>
        </a>
        <div class="nav-section-label">Users</div>
        <a class="sidebar-link active" href="/AdminUser">
            <span class="s-icon">👥</span><span>All Users</span>
        </a>
        <div class="nav-section-label">Questions</div>
        <a class="sidebar-link" href="/Admin/Questions?moduleId=1">
            <span class="s-icon">📝</span><span>Module 1</span>
        </a>
        <a class="sidebar-link" href="/Admin/Questions?moduleId=2">
            <span class="s-icon">📝</span><span>Module 2</span>
        </a>
        <a class="sidebar-link" href="/Admin/Questions?moduleId=3">
            <span class="s-icon">📝</span><span>Module 3</span>
        </a>
        <div class="nav-section-label">Sessions</div>
        <a class="sidebar-link" href="/AdminSession">
            <span class="s-icon">🕐</span><span>Exam Sessions</span>
        </a>
            <span class="s-icon">📈</span><span>Exam Results</span>
        </a>
    </div>

    <div class="dash-main">

        <a class="btn-back" href="/AdminUser">
            <i class="fa-solid fa-arrow-left"></i> Back to Users
        </a>

        <div class="user-hero">
            <div class="user-avatar-lg">
                @Model.Email?.Substring(0, 1).ToUpper()
            </div>
            <div>
                <h2>@Model.UserName</h2>
                <p>@Model.Email</p>
            </div>
        </div>

        <div class="detail-card">
            <div class="detail-row">
                <span class="detail-label">
                    <i class="fa-solid fa-envelope"></i> Email
                </span>
                <span class="detail-value">@Model.Email</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">
                    <i class="fa-solid fa-user"></i> Username
                </span>
                <span class="detail-value">@Model.UserName</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">
                    <i class="fa-solid fa-id-card"></i> Student ID
                </span>
                <span class="detail-value">@(profile?.StudentId ?? "Not assigned")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">
                    <i class="fa-solid fa-signature"></i> Full Name
                </span>
                <span class="detail-value">@(profile?.FullName ?? "—")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">
                    <i class="fa-solid fa-shield-halved"></i> Roles
                </span>
                <span class="detail-value">@string.Join(", ", (IList<string>)ViewBag.Roles)</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">
                    <i class="fa-solid fa-lock"></i> Exam Permission
                </span>
                <span class="detail-value">
                    @if (isPermitted)
                    {
                        <span class="badge-permitted">✅ Permitted</span>
                    }
                    else
                    {
                        <span class="badge-not-permitted">🚫 Not Permitted</span>
                    }
                </span>
            </div>
        </div>

        <div class="section-title">
            <i class="fa-solid fa-bolt" style="color:#635bff;margin-right:6px;"></i>
            Actions
        </div>
        <div class="actions-grid">
            <a class="btn-action btn-purple" href="/AdminUser/AssignStudentId/@Model.Id">
                <i class="fa-solid fa-id-card"></i> Assign Student ID
            </a>
            <a class="btn-action btn-green" href="/AdminUser/GrantPermission?id=@Model.Id">
                <i class="fa-solid fa-circle-check"></i> Grant Permission
            </a>
            <a class="btn-action btn-red" href="/AdminUser/RevokePermission?id=@Model.Id">
                <i class="fa-solid fa-ban"></i> Revoke Permission
            </a>
            <a class="btn-action btn-dark" href="/AdminUser/ResetPassword/@Model.Id">
                <i class="fa-solid fa-key"></i> Reset Password
            </a>
            <a class="btn-action btn-red"
               href="/AdminUser/DeleteUser/@Model.Id"
               onclick="return confirm('Are you sure? This will permanently delete the user and all their data.')">
                <i class="fa-solid fa-trash"></i> Delete User
            </a>
        </div>

    </div>
</div>