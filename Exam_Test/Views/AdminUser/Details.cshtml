@model Microsoft.AspNetCore.Identity.IdentityUser

@{
    ViewData["Title"] = "User Details";
    var profile = ViewBag.Profile as Exam_Test.Models.UserProfile;
    var permission = ViewBag.Permission as Exam_Test.Models.ExamPermission;
}

<style>
    .admin-wrap { display: flex; min-height: calc(100vh - 60px); background: #f0f2f8; }
    .sidebar { width: 230px; background: #1e2a3a; color: #fff; display: flex; flex-direction: column; padding: 24px 0; flex-shrink: 0; }
    .sidebar-brand { font-size: 16px; font-weight: 700; color: #fff; padding: 0 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 16px; }
    .sidebar-brand span { color: #6366f1; }
    .sidebar-label { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 1.2px; padding: 0 20px; margin: 10px 0 6px; }
    .sidebar a { display: flex; align-items: center; gap: 10px; padding: 10px 20px; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 13px; font-weight: 500; border-left: 3px solid transparent; transition: 0.2s; }
    .sidebar a:hover, .sidebar a.active { background: rgba(99,102,241,0.12); color: #fff; border-left-color: #6366f1; }
    .sidebar a .icon { font-size: 15px; width: 20px; text-align: center; }
    .main { flex: 1; padding: 28px; }
    .page-title { font-size: 22px; font-weight: 700; color: #111827; margin-bottom: 20px; }
    .detail-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 24px; max-width: 600px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); margin-bottom: 20px; }
    .detail-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #f3f4f6; font-size: 13px; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { font-weight: 600; color: #6b7280; }
    .detail-value { color: #111827; }
    .badge-green { background: #dcfce7; color: #166534; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
    .badge-red { background: #fee2e2; color: #991b1b; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
    .actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
    .btn-sm { display: inline-block; padding: 9px 16px; border-radius: 10px; font-size: 12px; font-weight: 600; text-decoration: none; color: #fff; transition: 0.2s; }
    .btn-purple { background: #6366f1; }
    .btn-purple:hover { background: #4f46e5; color: #fff; }
    .btn-green { background: #10b981; }
    .btn-green:hover { background: #059669; color: #fff; }
    .btn-red { background: #ef4444; }
    .btn-red:hover { background: #dc2626; color: #fff; }
    .btn-dark { background: #1e2a3a; }
    .btn-dark:hover { background: #374151; color: #fff; }
    .back-btn { display: inline-block; margin-bottom: 20px; padding: 8px 16px; border-radius: 10px; background: #1e2a3a; color: #fff; text-decoration: none; font-size: 13px; font-weight: 600; }
    .back-btn:hover { background: #374151; color: #fff; }
</style>

<div class="admin-wrap">
    <div class="sidebar">
        <div class="sidebar-brand">TVDE <span>Admin</span></div>
        <div class="sidebar-label">Main</div>
        <a href="/Admin/Dashboard"><span class="icon">📊</span> Dashboard</a>
        <div class="sidebar-label">Users</div>
        <a href="/AdminUser" class="active"><span class="icon">👥</span> All Users</a>
        <div class="sidebar-label">Questions</div>
        <a href="/Admin/Questions?moduleId=1"><span class="icon">📝</span> Module 1</a>
        <a href="/Admin/Questions?moduleId=2"><span class="icon">📝</span> Module 2</a>
        <a href="/Admin/Questions?moduleId=3"><span class="icon">📝</span> Module 3</a>
        <div class="sidebar-label">Sessions</div>
        <a href="/AdminSession"><span class="icon">🕐</span> Exam Sessions</a>
        <div class="sidebar-label">Reports</div>
        <a href="/AdminResult"><span class="icon">📈</span> Exam Results</a>
    </div>

    <div class="main">
        <a class="back-btn" href="/AdminUser">← Back to Users</a>
        <div class="page-title">👤 User Details</div>

        <div class="detail-card">
            <div class="detail-row">
                <span class="detail-label">Email</span>
                <span class="detail-value">@Model.Email</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Username</span>
                <span class="detail-value">@Model.UserName</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Student ID</span>
                <span class="detail-value"><b>@(profile?.StudentId ?? "Not assigned")</b></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Full Name</span>
                <span class="detail-value">@(profile?.FullName ?? "—")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Roles</span>
                <span class="detail-value">@string.Join(", ", (IList<string>)ViewBag.Roles)</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Exam Permission</span>
                <span class="detail-value">
                    @if (permission != null && permission.IsPermitted)
                    {
                        <span class="badge-green">✅ Permitted</span>
                    }
                    else
                    {
                        <span class="badge-red">🚫 Not Permitted</span>
                    }
                </span>
            </div>
        </div>

        <div class="actions">
            <a class="btn-sm btn-purple" href="/AdminUser/AssignStudentId/@Model.Id">🪪 Assign Student ID</a>
            <a class="btn-sm btn-green" href="/AdminUser/GrantPermission?id=@Model.Id">✅ Grant Permission</a>
            <a class="btn-sm btn-red" href="/AdminUser/RevokePermission?id=@Model.Id">🚫 Revoke Permission</a>
            <a class="btn-sm btn-dark" href="/AdminUser/ResetPassword/@Model.Id">🔑 Reset Password</a>
        </div>
    </div>
</div>