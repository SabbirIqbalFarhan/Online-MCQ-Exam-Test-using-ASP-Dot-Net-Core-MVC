@{
    ViewData["Title"] = "Assign Student ID";
}

<style>
    .admin-wrap { display: flex; min-height: calc(100vh - 60px); background: #f0f2f8; }
    .sidebar { width: 230px; background: #1e2a3a; color: #fff; display: flex; flex-direction: column; padding: 24px 0; flex-shrink: 0; }
    .sidebar-brand { font-size: 16px; font-weight: 700; color: #fff; padding: 0 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 16px; }
    .sidebar-brand span { color: #6366f1; }
    .sidebar-label { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 1.2px; padding: 0 20px; margin: 10px 0 6px; }
    .sidebar a { display: flex; align-items: center; gap: 10px; padding: 10px 20px; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 13px; font-weight: 500; border-left: 3px solid transparent; transition: 0.2s; }
    .sidebar a:hover, .sidebar a.active { background: rgba(99,102,241,0.12); color: #fff; border-left-color: #6366f1; }
    .sidebar a .icon { font-size: 15px; width: 20px; text-align: center; }
    .main { flex: 1; padding: 28px; }
    .page-title { font-size: 22px; font-weight: 700; color: #111827; margin-bottom: 4px; }
    .page-sub { font-size: 13px; color: #6b7280; margin-bottom: 24px; }
    .form-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 28px; max-width: 500px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
    .form-group { margin-bottom: 18px; }
    label { display: block; font-size: 12px; font-weight: 600; color: #374151; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.6px; }
    input { width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid #e5e7eb; font-size: 13px; outline: none; transition: 0.2s; }
    input:focus { border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,0.1); }
    .btn-submit { padding: 11px 24px; border-radius: 10px; background: #4f46e5; color: #fff; font-size: 13px; font-weight: 600; border: none; cursor: pointer; }
    .btn-submit:hover { background: #3730a3; }
    .back-btn { display: inline-block; margin-bottom: 20px; padding: 8px 16px; border-radius: 10px; background: #1e2a3a; color: #fff; text-decoration: none; font-size: 13px; font-weight: 600; }
    .back-btn:hover { background: #374151; color: #fff; }
    .info-box { background: #f8f9ff; border: 1px solid #e0e7ff; border-radius: 10px; padding: 12px 16px; margin-bottom: 20px; font-size: 13px; color: #374151; }
</style>

<div class="admin-wrap">
    <div class="sidebar">
        <div class="sidebar-brand">TVDE <span>Admin</span></div>
        <div class="sidebar-label">Main</div>
        <a href="/Admin/Dashboard"><span class="icon">📊</span> Dashboard</a>
        <div class="sidebar-label">Users</div>
        <a href="/AdminUser" class="active"><span class="icon">👥</span> All Users</a>
        <div class="sidebar-label">Questions</div>
        <a href="/Admin/Questions?moduleId=1"><span class="icon">📝</span> Module 1</a>
        <a href="/Admin/Questions?moduleId=2"><span class="icon">📝</span> Module 2</a>
        <a href="/Admin/Questions?moduleId=3"><span class="icon">📝</span> Module 3</a>
        <div class="sidebar-label">Sessions</div>
        <a href="/AdminSession"><span class="icon">🕐</span> Exam Sessions</a>
        <div class="sidebar-label">Reports</div>
        <a href="/AdminResult"><span class="icon">📈</span> Exam Results</a>
    </div>

    <div class="main">
        <a class="back-btn" href="/AdminUser/Details/@ViewBag.UserId">← Back to User</a>

        <div class="page-title">🪪 Assign Student ID</div>
        <div class="page-sub">Assign a student ID and full name to identify this user in exam results</div>

        <div class="info-box">
            👤 <strong>User:</strong> @ViewBag.UserEmail
            @if (ViewBag.CurrentStudentId != null)
            {
                <span>&nbsp;|&nbsp; Current ID: <strong>@ViewBag.CurrentStudentId</strong></span>
            }
        </div>

        <div class="form-card">
            <form method="post" action="/AdminUser/AssignStudentId/@ViewBag.UserId">
                <div class="form-group">
                    <label>Student ID</label>
                    <input type="text" name="studentId" value="@ViewBag.CurrentStudentId" placeholder="e.g. TVD73741905" required />
                </div>
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="fullName" value="@ViewBag.CurrentFullName" placeholder="e.g. John Smith" required />
                </div>
                <button type="submit" class="btn-submit">💾 Save</button>
            </form>
        </div>
    </div>
</div>