@model List<Exam_Test.Models.ExamSession>

@{
    ViewData["Title"] = "Exam Sessions";
}

<style>
    .admin-wrap { display: flex; min-height: calc(100vh - 60px); background: #f0f2f8; }
    .sidebar { width: 230px; background: #1e2a3a; color: #fff; display: flex; flex-direction: column; padding: 24px 0; flex-shrink: 0; }
    .sidebar-brand { font-size: 16px; font-weight: 700; color: #fff; padding: 0 20px 24px; border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 16px; }
    .sidebar-brand span { color: #6366f1; }
    .sidebar-label { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 1.2px; padding: 0 20px; margin: 10px 0 6px; }
    .sidebar a { display: flex; align-items: center; gap: 10px; padding: 10px 20px; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 13px; font-weight: 500; border-left: 3px solid transparent; transition: 0.2s; }
    .sidebar a:hover, .sidebar a.active { background: rgba(99,102,241,0.12); color: #fff; border-left-color: #6366f1; }
    .sidebar a .icon { font-size: 15px; width: 20px; text-align: center; }
    .main { flex: 1; padding: 28px; overflow-y: auto; }
    .page-title { font-size: 22px; font-weight: 700; color: #111827; margin-bottom: 4px; }
    .page-sub { font-size: 13px; color: #6b7280; margin-bottom: 24px; }
    .top-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .btn-add { display: inline-block; padding: 10px 18px; border-radius: 10px; background: #4f46e5; color: #fff; text-decoration: none; font-size: 13px; font-weight: 600; transition: 0.2s; }
    .btn-add:hover { background: #3730a3; color: #fff; }
    .table-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
    table { width: 100%; border-collapse: collapse; }
    thead { background: #1e2a3a; color: #fff; }
    th, td { padding: 13px 16px; font-size: 13px; text-align: left; }
    tbody tr { border-bottom: 1px solid #f3f4f6; transition: 0.2s; }
    tbody tr:hover { background: #f8f9ff; }
    .badge-green { background: #dcfce7; color: #166534; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
    .badge-gray { background: #f3f4f6; color: #6b7280; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
    .btn-sm { display: inline-block; padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 600; text-decoration: none; margin-right: 4px; transition: 0.2s; color: #fff; }
    .btn-activate { background: #10b981; }
    .btn-activate:hover { background: #059669; color: #fff; }
    .btn-deactivate { background: #f59e0b; }
    .btn-deactivate:hover { background: #d97706; color: #fff; }
    .btn-results { background: #6366f1; }
    .btn-results:hover { background: #4f46e5; color: #fff; }
    .btn-delete { background: #ef4444; }
    .btn-delete:hover { background: #dc2626; color: #fff; }
</style>

<div class="admin-wrap">
    <div class="sidebar">
        <div class="sidebar-brand">TVDE <span>Admin</span></div>
        <div class="sidebar-label">Main</div>
        <a href="/Admin/Dashboard"><span class="icon">📊</span> Dashboard</a>
        <div class="sidebar-label">Users</div>
        <a href="/AdminUser"><span class="icon">👥</span> All Users</a>
        <div class="sidebar-label">Questions</div>
        <a href="/Admin/Questions?moduleId=1"><span class="icon">📝</span> Module 1</a>
        <a href="/Admin/Questions?moduleId=2"><span class="icon">📝</span> Module 2</a>
        <a href="/Admin/Questions?moduleId=3"><span class="icon">📝</span> Module 3</a>
        <div class="sidebar-label">Sessions</div>
        <a href="/AdminSession" class="active"><span class="icon">🕐</span> Exam Sessions</a>
        <div class="sidebar-label">Reports</div>
        <a href="/AdminResult"><span class="icon">📈</span> Exam Results</a>
    </div>

    <div class="main">
        <div class="top-row">
            <div>
                <div class="page-title">🕐 Exam Sessions</div>
                <div class="page-sub">Create and manage exam sessions</div>
            </div>
            <a class="btn-add" href="/AdminSession/Create">+ New Session</a>
        </div>

        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Start Time</th>
                        <th>End Time</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td><b>@s.Title</b></td>
                                <td>@s.StartTime.ToString("dd MMM yyyy, hh:mm tt")</td>
                                <td>@s.EndTime.ToString("dd MMM yyyy, hh:mm tt")</td>
                                <td>
                                    @if (s.IsActive)
                                    {
                                        <span class="badge-green">🟢 Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-gray">⚫ Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (!s.IsActive)
                                    {
                                        <a class="btn-sm btn-activate" href="/AdminSession/Activate?id=@s.Id">Activate</a>
                                    }
                                    else
                                    {
                                        <a class="btn-sm btn-deactivate" href="/AdminSession/Deactivate?id=@s.Id">Deactivate</a>
                                    }
                                    <a class="btn-sm btn-results" href="/AdminSession/Results?id=@s.Id">Results</a>
                                    <a class="btn-sm btn-delete" href="/AdminSession/Delete?id=@s.Id">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" style="text-align:center; color:#9ca3af; padding:30px;">No sessions created yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>