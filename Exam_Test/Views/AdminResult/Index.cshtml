@model List<Exam_Test.Models.Result>

@{
    ViewData["Title"] = "Exam Results";
    int selectedModule = ViewBag.ModuleId ?? 0;
    string selectedUserId = ViewBag.UserId ?? "";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalCount = ViewBag.TotalCount ?? 0;
}

<style>
    .admin-wrap {
    display: flex;
    min-height: calc(100vh - 60px);
    background: #f1f4fb;
    margin: -28px; /* cancel page-wrapper padding */
}
.dash-main {
    flex: 1;
    padding: 28px;
    overflow-y: auto;
}
   .dash-sidebar {
    width: 230px;
    background: #1a2236;
    flex-shrink: 0;
    padding: 60px 0 24px; /* was 24px 0 */
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}
.nav-section-label { font-size: 9.5px; font-weight: 700; color: rgba(240,244,255,0.35); text-transform: uppercase; letter-spacing: 1.4px; padding: 14px 20px 6px; }
    .sidebar-link { display: flex; align-items: center; gap: 11px; padding: 9px 20px; color: rgba(240,244,255,0.62); text-decoration: none; font-size: 13px; font-weight: 500; border-left: 3px solid transparent; transition: all 0.18s; }
    .sidebar-link:hover { color: #fff; background: rgba(99,91,255,0.1); border-left-color: rgba(99,91,255,0.5); }
    .sidebar-link.active { color: #fff; background: rgba(99,91,255,0.15); border-left-color: #635bff; }
    .sidebar-link .s-icon { width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center; font-size: 14px; flex-shrink: 0; background: rgba(255,255,255,0.06); }
    .sidebar-link:hover .s-icon, .sidebar-link.active .s-icon { background: rgba(99,91,255,0.25); }
    .page-header { margin-bottom: 24px; }
    .page-header h2 { font-size: 22px; font-weight: 800; color: #1a2236; margin: 0 0 4px; }
    .page-header p { font-size: 13px; color: #64748b; margin: 0; }
    .filter-card { background: #fff; border: 1px solid #e5e9f2; border-radius: 14px; padding: 16px 20px; display: flex; align-items: center; gap: 12px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(26,34,54,0.04); flex-wrap: wrap; }
    .filter-label { font-size: 12px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.7px; }
    .filter-card select, .filter-card input[type=text] { padding: 9px 14px; border-radius: 10px; border: 1.5px solid #e2e8f0; font-size: 13.5px; font-family: 'Plus Jakarta Sans', sans-serif; color: #1e293b; background: #f8fafc; outline: none; transition: 0.18s; }
    .filter-card select:focus, .filter-card input[type=text]:focus { border-color: #635bff; background: #fff; box-shadow: 0 0 0 3px rgba(99,91,255,0.1); }
    .btn-filter { display: inline-flex; align-items: center; gap: 7px; padding: 9px 18px; border-radius: 10px; background: #635bff; color: #fff; font-size: 13px; font-weight: 700; font-family: 'Plus Jakarta Sans', sans-serif; border: none; cursor: pointer; transition: 0.2s; box-shadow: 0 4px 12px rgba(99,91,255,0.3); }
    .btn-filter:hover { background: #4f46e5; }
    .summary-pill { background: rgba(99,91,255,0.08); border: 1px solid rgba(99,91,255,0.15); color: #635bff; padding: 5px 14px; border-radius: 999px; font-size: 12px; font-weight: 700; margin-left: auto; }
    .table-card { background: #fff; border: 1px solid #e5e9f2; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 8px rgba(26,34,54,0.04); }
    .table-card table { width: 100%; border-collapse: collapse; }
    .table-card thead { background: #1a2236; }
    .table-card th { padding: 13px 16px; font-size: 11px; font-weight: 700; color: rgba(240,244,255,0.6); text-transform: uppercase; letter-spacing: 0.8px; text-align: left; }
    .table-card td { padding: 13px 16px; font-size: 13px; color: #374151; text-align: left; }
    .table-card tbody tr { border-bottom: 1px solid #f1f5f9; transition: 0.18s; }
    .table-card tbody tr:last-child { border-bottom: none; }
    .table-card tbody tr:hover { background: #f8f9ff; }
    .user-cell { display: flex; align-items: center; gap: 9px; }
    .user-avatar { width: 30px; height: 30px; border-radius: 50%; background: rgba(99,91,255,0.12); display: grid; place-items: center; font-size: 11px; font-weight: 800; color: #635bff; flex-shrink: 0; }
    .user-id-text { font-size: 12.5px; font-weight: 600; color: #1a2236; max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .module-pill { background: rgba(99,91,255,0.1); color: #635bff; padding: 4px 12px; border-radius: 999px; font-size: 11.5px; font-weight: 700; }
    .badge-green { background: #dcfce7; color: #166534; padding: 4px 12px; border-radius: 999px; font-size: 11.5px; font-weight: 700; }
    .badge-red { background: #fee2e2; color: #991b1b; padding: 4px 12px; border-radius: 999px; font-size: 11.5px; font-weight: 700; }
    .date-cell { font-size: 12.5px; color: #64748b; }
    .btn-del { display: inline-flex; align-items: center; gap: 5px; padding: 5px 10px; border-radius: 7px; background: #ef4444; color: #fff; font-size: 12px; font-weight: 700; text-decoration: none; transition: 0.18s; }
    .btn-del:hover { background: #dc2626; color: #fff; }
    .empty-state { text-align: center; padding: 50px 20px; color: #94a3b8; }
    .empty-state .e-icon { font-size: 36px; margin-bottom: 10px; }
    .empty-state p { font-size: 13px; margin: 0; }
    .pagination { display: flex; align-items: center; gap: 6px; margin-top: 20px; justify-content: center; }
    .page-btn { padding: 8px 14px; border-radius: 8px; border: 1.5px solid #e2e8f0; background: #fff; color: #374151; font-size: 13px; font-weight: 600; text-decoration: none; transition: 0.18s; }
    .page-btn:hover { background: #f8f9ff; border-color: #635bff; color: #635bff; }
    .page-btn.active { background: #635bff; color: #fff; border-color: #635bff; }
    .page-btn.disabled { opacity: 0.4; pointer-events: none; }
</style>

<div class="admin-wrap">
    <div class="dash-sidebar">
        <div class="nav-section-label">Main</div>
        <a class="sidebar-link" href="/Admin/Dashboard"><span class="s-icon">📊</span><span>Dashboard</span></a>
        <div class="nav-section-label">Users</div>
        <a class="sidebar-link" href="/AdminUser"><span class="s-icon">👥</span><span>All Users</span></a>
        <div class="nav-section-label">Questions</div>
        <a class="sidebar-link" href="/Admin/Questions?moduleId=1"><span class="s-icon">📝</span><span>Module 1</span></a>
        <a class="sidebar-link" href="/Admin/Questions?moduleId=2"><span class="s-icon">📝</span><span>Module 2</span></a>
        <a class="sidebar-link" href="/Admin/Questions?moduleId=3"><span class="s-icon">📝</span><span>Module 3</span></a>
        <div class="nav-section-label">Sessions</div>
        <a class="sidebar-link" href="/AdminSession"><span class="s-icon">🕐</span><span>Exam Sessions</span></a>
        <div class="nav-section-label">Reports</div>
        <a class="sidebar-link active" href="/AdminResult"><span class="s-icon">📈</span><span>Exam Results</span></a>
    </div>

    <div class="dash-main">
        <div class="page-header">
            <h2><i class="fa-solid fa-chart-line" style="color:#635bff;margin-right:8px;"></i>Exam Results</h2>
            <p>View, filter, and manage all student exam results</p>
        </div>

        <form method="get" class="filter-card">
            <span class="filter-label"><i class="fa-solid fa-filter" style="margin-right:4px;"></i> Filter by</span>
            <select name="moduleId">
                <option value="">All Modules</option>
                @if (selectedModule == 1) { <option value="1" selected>Module 1</option> } else { <option value="1">Module 1</option> }
                @if (selectedModule == 2) { <option value="2" selected>Module 2</option> } else { <option value="2">Module 2</option> }
                @if (selectedModule == 3) { <option value="3" selected>Module 3</option> } else { <option value="3">Module 3</option> }
            </select>
            <input type="text" name="userId" placeholder="Search by User ID..." value="@selectedUserId" style="min-width:200px;" />
            <button type="submit" class="btn-filter"><i class="fa-solid fa-magnifying-glass"></i> Apply Filter</button>
            <span class="summary-pill"><i class="fa-solid fa-list" style="margin-right:4px;"></i> @totalCount result@(totalCount != 1 ? "s" : "")</span>
        </form>

        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Module</th>
                        <th>Correct</th>
                        <th>Wrong</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar">@r.UserId?.Substring(0, 1).ToUpper()</div>
                                        <span class="user-id-text" title="@r.UserId">@r.UserId</span>
                                    </div>
                                </td>
                                <td><span class="module-pill">Module @r.ModuleId</span></td>
                                <td><span class="badge-green">✓ @r.Correct</span></td>
                                <td><span class="badge-red">✗ @r.Wrong</span></td>
                                <td>
                                    <span class="date-cell">
                                        <i class="fa-regular fa-clock" style="margin-right:5px;"></i>
                                        @r.ExamDate.ToString("yyyy-MM-dd HH:mm")
                                    </span>
                                </td>
                                <td>
                                    <a class="btn-del"
                                       href="/AdminResult/Delete/@r.Id"
                                       onclick="return confirm('Delete this result?')">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <div class="e-icon">📭</div>
                                    <p>No results found for the selected filter.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div class="pagination">
                <a href="?moduleId=@selectedModule&userId=@selectedUserId&page=@(currentPage - 1)"
                   class="page-btn @(currentPage == 1 ? "disabled" : "")">
                    <i class="fa-solid fa-chevron-left"></i>
                </a>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a href="?moduleId=@selectedModule&userId=@selectedUserId&page=@i"
                       class="page-btn @(i == currentPage ? "active" : "")">@i</a>
                }
                <a href="?moduleId=@selectedModule&userId=@selectedUserId&page=@(currentPage + 1)"
                   class="page-btn @(currentPage == totalPages ? "disabled" : "")">
                    <i class="fa-solid fa-chevron-right"></i>
                </a>
            </div>
        }

    </div>
</div>