@model List<Exam_Test.Models.Result>

@{
    ViewData["Title"] = "Exam Results";
}

<style>
    .admin-wrap {
        display: flex;
        min-height: calc(100vh - 60px);
        background: #f0f2f8;
    }

    .sidebar {
        width: 230px;
        background: #1e2a3a;
        color: #fff;
        display: flex;
        flex-direction: column;
        padding: 24px 0;
        flex-shrink: 0;
    }

    .sidebar-brand {
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        padding: 0 20px 24px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        margin-bottom: 16px;
    }

    .sidebar-brand span { color: #6366f1; }

    .sidebar-label {
        font-size: 10px;
        font-weight: 600;
        color: rgba(255,255,255,0.35);
        text-transform: uppercase;
        letter-spacing: 1.2px;
        padding: 0 20px;
        margin: 10px 0 6px;
    }

    .sidebar a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        border-left: 3px solid transparent;
        transition: 0.2s;
    }

    .sidebar a:hover, .sidebar a.active {
        background: rgba(99,102,241,0.12);
        color: #fff;
        border-left-color: #6366f1;
    }

    .sidebar a .icon { font-size: 15px; width: 20px; text-align: center; }

    .main {
        flex: 1;
        padding: 28px;
        overflow-y: auto;
    }

    .page-title {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 4px;
    }

    .page-sub {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 24px;
    }

    .filter-box {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 14px 18px;
        display: flex;
        gap: 10px;
        align-items: center;
        margin-bottom: 20px;
    }

    select {
        padding: 9px 12px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        font-size: 13px;
        outline: none;
        background: #fff;
    }

    select:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79,70,229,0.12);
    }

    .btn-filter {
        padding: 9px 16px;
        border-radius: 10px;
        background: #4f46e5;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn-filter:hover { background: #3730a3; }

    .table-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: #1e2a3a;
        color: #fff;
    }

    th, td {
        padding: 13px 16px;
        font-size: 13px;
        text-align: left;
    }

    tbody tr {
        border-bottom: 1px solid #f3f4f6;
        transition: 0.2s;
    }

    tbody tr:hover { background: #f8f9ff; }

    .badge-green {
        background: #dcfce7;
        color: #166534;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-red {
        background: #fee2e2;
        color: #991b1b;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 600;
    }

    .empty {
        text-align: center;
        padding: 40px;
        color: #9ca3af;
        font-size: 14px;
    }
</style>

<div class="admin-wrap">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-brand">TVDE <span>Admin</span></div>

        <div class="sidebar-label">Main</div>
        <a href="/Admin/Dashboard">
            <span class="icon">📊</span> Dashboard
        </a>

        <div class="sidebar-label">Users</div>
        <a href="/AdminUser">
            <span class="icon">👥</span> All Users
        </a>

        <div class="sidebar-label">Questions</div>
        <a href="/Admin/Questions?moduleId=1">
            <span class="icon">📝</span> Module 1
        </a>
        <a href="/Admin/Questions?moduleId=2">
            <span class="icon">📝</span> Module 2
        </a>
        <a href="/Admin/Questions?moduleId=3">
            <span class="icon">📝</span> Module 3
        </a>

        <div class="sidebar-label">Sessions</div>
        <a href="/AdminSession">
            <span class="icon">🕐</span> Exam Sessions
        </a>

        <div class="sidebar-label">Reports</div>
        <a href="/AdminResult">
            <span class="icon">📈</span> Exam Results
        </a>
    </div>

    <!-- MAIN -->
    <div class="main">

        <div class="page-title">📈 Exam Results</div>
        <div class="page-sub">View and filter all student exam results</div>

        <!-- FILTER -->
        <form method="get" class="filter-box">
            @{
                int selectedModule = ViewBag.ModuleId ?? 0;
            }
            <select name="moduleId">
                <option value="">All Modules</option>
                @if (selectedModule == 1)
                {
                    <option value="1" selected>Module 1</option>
                }
                else
                {
                    <option value="1">Module 1</option>
                }
                @if (selectedModule == 2)
                {
                    <option value="2" selected>Module 2</option>
                }
                else
                {
                    <option value="2">Module 2</option>
                }
                @if (selectedModule == 3)
                {
                    <option value="3" selected>Module 3</option>
                }
                else
                {
                    <option value="3">Module 3</option>
                }
            </select>
            <button type="submit" class="btn-filter">Filter</button>
        </form>

        <!-- TABLE -->
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Module</th>
                        <th>Correct</th>
                        <th>Wrong</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>@r.UserId</td>
                                <td>Module @r.ModuleId</td>
                                <td><span class="badge-green">@r.Correct</span></td>
                                <td><span class="badge-red">@r.Wrong</span></td>
                                <td>@r.ExamDate.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="empty">📭 No results found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>