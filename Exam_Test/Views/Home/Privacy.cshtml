@{
    ViewData["Title"] = "Privacy Policy";
}

<style>
    .privacy-wrap {
        max-width: 760px;
        margin: 0 auto;
        padding: 40px 20px 80px;
    }

    .privacy-header {
        background: #1a2236;
        border-radius: 20px;
        padding: 36px 32px;
        text-align: center;
        margin-bottom: 28px;
    }

    .privacy-header-icon {
        width: 52px;
        height: 52px;
        background: #635bff;
        border-radius: 14px;
        display: grid;
        place-items: center;
        font-size: 22px;
        color: #fff;
        margin: 0 auto 16px;
        box-shadow: 0 6px 20px rgba(99,91,255,0.45);
    }

    .privacy-header h1 {
        font-size: 22px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 6px;
    }

    .privacy-header p {
        font-size: 13px;
        color: rgba(255,255,255,0.5);
        margin: 0 0 16px;
    }

    .privacy-pills {
        display: flex;
        justify-content: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .privacy-pill {
        font-size: 11px;
        padding: 4px 12px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.2);
        background: rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.7);
        font-weight: 600;
    }

    .section-label {
        font-size: 11px;
        font-weight: 700;
        color: #635bff;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        margin-bottom: 14px;
    }

    .pp-card {
        background: #fff;
        border: 1px solid #e5e9f2;
        border-radius: 14px;
        padding: 18px 20px;
        display: flex;
        gap: 14px;
        align-items: flex-start;
        margin-bottom: 12px;
        transition: 0.18s;
        box-shadow: 0 2px 8px rgba(26,34,54,0.04);
    }

        .pp-card:hover {
            border-color: #d4d0ff;
            box-shadow: 0 8px 24px rgba(99,91,255,0.08);
            transform: translateY(-2px);
        }

    .pp-icon {
        width: 42px;
        height: 42px;
        background: rgba(99,91,255,0.1);
        border-radius: 10px;
        display: grid;
        place-items: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .pp-content h3 {
        font-size: 14.5px;
        font-weight: 700;
        color: #1a2236;
        margin: 0 0 5px;
    }

    .pp-content p {
        font-size: 13px;
        color: #64748b;
        line-height: 1.6;
        margin: 0;
    }

    .pp-note {
        margin-top: 6px;
        font-size: 12px;
        color: #635bff;
        font-weight: 600;
    }

    .pp-footer {
        text-align: center;
        margin-top: 24px;
        font-size: 12px;
        color: #94a3b8;
    }
</style>

<div class="privacy-wrap">

    <div class="privacy-header">
        <div class="privacy-header-icon">
            <i class="fa-solid fa-shield-halved"></i>
        </div>
        <h1>Privacy Policy</h1>
        <p>We protect your data with secure systems and transparent policies</p>
        <div class="privacy-pills">
            <span class="privacy-pill">🔒 Secure</span>
            <span class="privacy-pill">🔐 Private</span>
            <span class="privacy-pill">✅ Safe</span>
        </div>
    </div>

    <div class="section-label">Our Commitments</div>

    <div class="pp-card">
        <div class="pp-icon">🔒</div>
        <div class="pp-content">
            <h3>Data Protection</h3>
            <p>Your personal information is securely stored and used only for authentication and exam tracking.</p>
            <div class="pp-note">We never sell or misuse your data.</div>
        </div>
    </div>

    <div class="pp-card">
        <div class="pp-icon">👤</div>
        <div class="pp-content">
            <h3>User Responsibility</h3>
            <p>Keep your login credentials safe and do not share them with others.</p>
        </div>
    </div>

    <div class="pp-card">
        <div class="pp-icon">📊</div>
        <div class="pp-content">
            <h3>Data Usage</h3>
            <p>Data is used only for exams, results, and system improvement. Nothing more.</p>
        </div>
    </div>

    <div class="pp-card">
        <div class="pp-icon">⚖️</div>
        <div class="pp-content">
            <h3>Policy Agreement</h3>
            <p>By using this system, you agree to our privacy policy and terms of use.</p>
        </div>
    </div>

    <div class="pp-footer">Last updated: 2026</div>

</div>