@{
    ViewData["Title"] = "Home Page";
}

<style>
    .hero-wrap {
        min-height: calc(100vh - 60px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px 40px;
        background: linear-gradient(135deg, #f1f4fb 0%, #e8ecf8 100%);
        text-align: center;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: rgba(99,91,255,0.1);
        border: 1px solid rgba(99,91,255,0.2);
        border-radius: 999px;
        padding: 6px 16px;
        font-size: 12px;
        font-weight: 700;
        color: #635bff;
        letter-spacing: 0.5px;
        margin-bottom: 24px;
    }

    .hero-title {
        font-size: 48px;
        font-weight: 800;
        color: #1a2236;
        line-height: 1.15;
        margin-bottom: 16px;
        max-width: 640px;
    }

    .hero-title span {
        color: #635bff;
    }

    .hero-sub {
        font-size: 15px;
        color: #64748b;
        line-height: 1.7;
        max-width: 480px;
        margin-bottom: 36px;
    }

    .hero-btns {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: center;
        margin-bottom: 64px;
    }

    .btn-hero-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 13px 28px;
        background: #635bff;
        color: #fff !important;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 6px 20px rgba(99,91,255,0.35);
        transition: 0.2s;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .btn-hero-primary:hover {
        background: #4f46e5;
        transform: translateY(-2px);
        box-shadow: 0 10px 28px rgba(99,91,255,0.45);
        color: #fff !important;
    }

    .btn-hero-outline {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 13px 28px;
        background: #fff;
        color: #1a2236 !important;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.2s;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .btn-hero-outline:hover {
        border-color: #635bff;
        color: #635bff !important;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0,0,0,0.06);
    }

    .stats-row {
        display: flex;
        gap: 32px;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 64px;
    }

    .stat-item { text-align: center; }

    .stat-item .num {
        font-size: 28px;
        font-weight: 800;
        color: #1a2236;
    }

    .stat-item .lbl {
        font-size: 12px;
        color: #94a3b8;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.6px;
    }

    .stat-divider {
        width: 1px;
        background: #e2e8f0;
        align-self: stretch;
    }

    .features-wrap {
        max-width: 960px;
        width: 100%;
        margin: 0 auto;
        padding: 0 20px 80px;
    }

    .features-title {
        text-align: center;
        font-size: 13px;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        margin-bottom: 24px;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
    }

    .feature-card {
        background: #fff;
        border: 1px solid #e5e9f2;
        border-radius: 16px;
        padding: 24px;
        transition: 0.2s;
        box-shadow: 0 2px 8px rgba(26,34,54,0.04);
    }

    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(26,34,54,0.1);
        border-color: #d4d0ff;
    }

    .feature-icon {
        width: 46px; height: 46px;
        border-radius: 12px;
        display: grid; place-items: center;
        font-size: 20px;
        margin-bottom: 14px;
    }

    .feature-icon.purple { background: rgba(99,91,255,0.1); }
    .feature-icon.cyan   { background: rgba(6,182,212,0.1); }
    .feature-icon.green  { background: rgba(16,185,129,0.1); }

    .feature-card h3 {
        font-size: 15px;
        font-weight: 700;
        color: #1a2236;
        margin: 0 0 8px;
    }

    .feature-card p {
        font-size: 13px;
        color: #64748b;
        line-height: 1.6;
        margin: 0;
    }
</style>

<div class="hero-wrap">

    <div class="hero-badge">
        <i class="fa-solid fa-graduation-cap"></i>
        Online Exam Platform
    </div>

    <h1 class="hero-title">
        Your Path to <span>Certification</span> Starts Here
    </h1>

    <p class="hero-sub">
        A modern exam system where you can take tests, practice questions,
        and track your performance with ease.
    </p>

    <div class="hero-btns">
        <a class="btn-hero-primary" href="/Identity/Account/Login">
            <i class="fa-solid fa-right-to-bracket"></i>
            Get Started
        </a>
        <a class="btn-hero-outline" href="/Identity/Account/Register">
            <i class="fa-solid fa-user-plus"></i>
            Create Account
        </a>
    </div>

    <div class="stats-row">
        <div class="stat-item">
            <div class="num">3</div>
            <div class="lbl">Modules</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="num">100%</div>
            <div class="lbl">Online</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="num">24/7</div>
            <div class="lbl">Available</div>
        </div>
    </div>

</div>

