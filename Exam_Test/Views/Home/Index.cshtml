@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f6f8fc;
        color: #111827;
    }

    .hero {
        max-width: 1000px;
        margin: auto;
        padding: 80px 20px;
        text-align: center;
    }

        .hero h1 {
            font-size: 40px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .hero p {
            font-size: 15px;
            color: #6b7280;
            margin-bottom: 30px;
            line-height: 1.6;
        }

    .btn {
        display: inline-block;
        padding: 12px 18px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        margin: 6px;
        transition: 0.2s;
    }

    .btn-primary {
        background: #4f46e5;
        color: #fff;
    }

        .btn-primary:hover {
            background: #3730a3;
        }

    .btn-outline {
        border: 1px solid #d1d5db;
        color: #111827;
        background: #fff;
    }

        .btn-outline:hover {
            border-color: #4f46e5;
            color: #4f46e5;
        }

    .features {
        max-width: 1000px;
        margin: auto;
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
        padding: 0 20px 60px;
    }

    .card {
        flex: 1 1 280px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 4px 14px rgba(0,0,0,0.03);
        transition: 0.2s;
    }

        .card:hover {
            transform: translateY(-3px);
        }

        .card h3 {
            margin: 0 0 8px;
            font-size: 17px;
        }

        .card p {
            font-size: 13px;
            color: #6b7280;
            line-height: 1.5;
        }
</style>

<div class="hero">

    <h1>Welcome to Exam Platform</h1>

    <p>
        A modern learning system where you can take exams, practice questions,
        and track your progress efficiently.
    </p>

    <a class="btn btn-primary" href="/Identity/Account/Login">Get Started</a>
    <a class="btn btn-outline" href="/Identity/Account/Register">Create Account</a>

</div>

<div class="features">

    <div class="card">
        <h3>📚 Practice Modules</h3>
        <p>Learn step by step using structured question modules.</p>
    </div>

    <div class="card">
        <h3>📝 Online Exams</h3>
        <p>Take exams anytime and improve your knowledge.</p>
    </div>

    <div class="card">
        <h3>📊 Performance Tracking</h3>
        <p>View your results and track improvement over time.</p>
    </div>

</div>