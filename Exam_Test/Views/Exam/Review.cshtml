@model List<Exam_Test.Models.UserAnswer>

@{
    ViewData["Title"] = "Answer Review";
    int moduleId = Context.Request.Query.ContainsKey("moduleId")
        ? int.Parse(Context.Request.Query["moduleId"])
        : 0;
    bool onlyWrong = Context.Request.Query["onlyWrong"] == "true";
    int totalQ    = Model.Count;
    int correctQ  = Model.Count(a => a.IsCorrect);
    int wrongQ    = totalQ - correctQ;
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f4f6ff;
        color: #111827;
    }

    .page {
        max-width: 900px;
        margin: auto;
        padding: 40px 20px;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .header h2 { font-size: 22px; font-weight: 700; margin: 0; }
    .header p  { font-size: 13px; color: #6b7280; margin-top: 5px; }

    .header-actions { display: flex; gap: 10px; flex-wrap: wrap; }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 16px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.2s;
        border: none;
        cursor: pointer;
    }
    .btn-primary { background: #4f46e5; color: #fff; }
    .btn-primary:hover { background: #3730a3; color: #fff; }
    .btn-outline { background: #fff; border: 1px solid #4f46e5; color: #4f46e5; }
    .btn-outline:hover { background: #eef2ff; }
    .btn-danger  { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
    .btn-danger:hover  { background: #fecaca; }
    .btn-active  { background: #4f46e5 !important; color: #fff !important; border-color: #4f46e5 !important; }

    /* SUMMARY BAR */
    .summary-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .sum-box {
        flex: 1;
        min-width: 120px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 14px 16px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }

    .sum-box .num { font-size: 22px; font-weight: 800; }
    .sum-box .lbl { font-size: 11px; color: #6b7280; margin-top: 2px; font-weight: 600; }
    .num-correct { color: #16a34a; }
    .num-wrong   { color: #dc2626; }
    .num-total   { color: #4f46e5; }

    /* CARDS */
    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 14px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.04);
        transition: 0.2s;
        border-left: 4px solid #e5e7eb;
    }
    .card:hover { transform: translateY(-2px); }
    .card.is-correct { border-left-color: #10b981; }
    .card.is-wrong   { border-left-color: #ef4444; }

    .q-num-badge {
        display: inline-block;
        background: #eef2ff;
        color: #4f46e5;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .question { font-size: 15px; font-weight: 600; margin-bottom: 10px; color: #111827; }

    .image { margin: 10px 0; }
    .image img { max-width: 240px; border-radius: 10px; border: 1px solid #e5e7eb; }

    .row { margin: 6px 0; font-size: 13px; display: flex; align-items: center; gap: 8px; }
    .label { font-weight: 600; color: #6b7280; min-width: 110px; }

    .correct { color: #16a34a; font-weight: 600; }
    .wrong   { color: #dc2626; font-weight: 600; }

    .status { margin-top: 10px; font-size: 13px; font-weight: 700; }

    .empty-state { text-align: center; padding: 48px 20px; color: #6b7280; background: #fff; border-radius: 16px; border: 1px solid #e5e7eb; }
    .empty-state .icon { font-size: 40px; margin-bottom: 12px; }
</style>

<div class="page">

    <div class="header">
        <div>
            <h2>📘 Answer Review — Module @moduleId</h2>
            <p>Check your answers and learn from mistakes</p>
        </div>
        <div class="header-actions">
            <a class="btn @(!onlyWrong ? "btn-active" : "btn-outline")"
               href="/Exam/Review?moduleId=@moduleId">
                📋 All Answers
            </a>
            <a class="btn @(onlyWrong ? "btn-active btn-danger" : "btn-danger")"
               href="/Exam/Review?moduleId=@moduleId&onlyWrong=true">
                ❌ Wrong Only (@wrongQ)
            </a>
            <a class="btn btn-primary" href="/Exam/History">📊 History</a>
            <a class="btn btn-outline" href="/User/Dashboard">← Dashboard</a>
        </div>
    </div>

    <!-- SUMMARY -->
    <div class="summary-bar">
        <div class="sum-box"><div class="num num-total">@totalQ</div><div class="lbl">Showing</div></div>
        <div class="sum-box"><div class="num num-correct">@correctQ</div><div class="lbl">Correct</div></div>
        <div class="sum-box"><div class="num num-wrong">@wrongQ</div><div class="lbl">Wrong</div></div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="icon">🎉</div>
            <p>@(onlyWrong ? "No wrong answers — perfect score!" : "No answers found for this module.")</p>
        </div>
    }

    @{ int qNum = 0; }
    @foreach (var item in Model)
    {
        qNum++;
        <div class="card @(item.IsCorrect ? "is-correct" : "is-wrong")">

            <span class="q-num-badge">Question @qNum</span>

            <div class="question">
                @(item.Question?.QuestionText ?? "—")
            </div>

            @if (item.Question?.ImagePath != null)
            {
                <div class="image">
                    <img src="~/images/@item.Question.ImagePath" alt="Question image" />
                </div>
            }

            <div class="row">
                <span class="label">Your Answer:</span>
                <span class="@(item.IsCorrect ? "correct" : "wrong")">
                    @(item.SelectedAnswer ?? "Not answered")
                </span>
            </div>

            <div class="row">
                <span class="label">Correct Answer:</span>
                <span class="correct">@(item.Question?.CorrectAnswer ?? "—")</span>
            </div>

            <div class="status">
                @if (item.IsCorrect)
                {
                    <span class="correct">✅ Correct</span>
                }
                else
                {
                    <span class="wrong">❌ Wrong</span>
                }
            </div>

        </div>
    }

</div>