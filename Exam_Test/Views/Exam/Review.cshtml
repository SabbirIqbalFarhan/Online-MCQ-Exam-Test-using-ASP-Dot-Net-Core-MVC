@model List<Exam_Test.Models.UserAnswer>

@{
    ViewData["Title"] = "Answer Review";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f4f6ff;
        color: #111827;
    }

    .page {
        max-width: 900px;
        margin: auto;
        padding: 40px 20px;
    }

    .header {
        margin-bottom: 18px;
    }

        .header h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

        .header p {
            font-size: 13px;
            color: #6b7280;
            margin-top: 5px;
        }

    /* CARD */
    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 14px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.04);
        transition: 0.2s;
    }

        .card:hover {
            transform: translateY(-2px);
        }

    .question {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 10px;
        color: #111827;
    }

    .image {
        margin: 10px 0;
    }

        .image img {
            max-width: 220px;
            border-radius: 10px;
            border: 1px solid #e5e7eb;
        }

    .row {
        margin: 6px 0;
        font-size: 13px;
    }

    .label {
        font-weight: 600;
        color: #6b7280;
    }

    /* BADGES */
    .correct {
        color: #16a34a;
        font-weight: 600;
    }

    .wrong {
        color: #dc2626;
        font-weight: 600;
    }

    .status {
        margin-top: 8px;
        font-size: 13px;
        font-weight: 600;
    }

</style>

<div class="page">

    <div class="header">
        <h2>📘 Answer Review</h2>
        <p>Check your answers and learn from mistakes</p>
    </div>

    @foreach (var item in Model)
    {
        <div class="card">

            <div class="question">
                @item.Question.QuestionText
            </div>

            @if (item.Question.ImagePath != null)
            {
                <div class="image">
                    <img src="~/images/@item.Question.ImagePath" />
                </div>
            }

            <div class="row">
                <span class="label">Your Answer:</span>
                <span class="@(item.IsCorrect ? "correct" : "wrong")">
                    @item.SelectedAnswer
                </span>
            </div>

            <div class="row">
                <span class="label">Correct Answer:</span>
                <span class="correct">
                    @item.Question.CorrectAnswer
                </span>
            </div>

            <div class="status">
                @if (!item.IsCorrect)
                {
                    <span class="wrong">❌ Wrong Answer</span>
                }
                else
                {
                    <span class="correct">✅ Correct Answer</span>
                }
            </div>

        </div>
    }

</div>