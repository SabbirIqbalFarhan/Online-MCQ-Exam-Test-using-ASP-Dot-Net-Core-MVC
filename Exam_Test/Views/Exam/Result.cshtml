@{
    ViewData["Title"] = "Exam Result";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f4f6ff;
        color: #111827;
    }

    .page {
        max-width: 700px;
        margin: auto;
        padding: 60px 20px;
        text-align: center;
    }

    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .title {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .stats {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin: 25px 0;
        flex-wrap: wrap;
    }

    .box {
        flex: 1;
        min-width: 140px;
        padding: 18px;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        background: #f9fafb;
    }

        .box h3 {
            margin: 0;
            font-size: 14px;
            color: #6b7280;
            font-weight: 500;
        }

        .box span {
            display: block;
            margin-top: 6px;
            font-size: 22px;
            font-weight: 700;
        }

    .correct {
        color: #16a34a;
    }

    .wrong {
        color: #dc2626;
    }

    /* BUTTON STYLE */
    .btn {
        display: inline-block;
        margin: 8px;
        padding: 10px 16px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        background: #4f46e5;
        color: #fff;
        transition: 0.2s;
    }

        .btn:hover {
            background: #3730a3;
        }

    .btn-outline {
        background: #fff;
        border: 1px solid #4f46e5;
        color: #4f46e5;
    }

        .btn-outline:hover {
            background: #eef2ff;
        }

</style>

<div class="page">

    <div class="card">

        <div class="title">🎯 Exam Result</div>

        <div class="stats">

            <div class="box">
                <h3>Correct Answers</h3>
                <span class="correct">@ViewBag.Correct</span>
            </div>

            <div class="box">
                <h3>Wrong Answers</h3>
                <span class="wrong">@ViewBag.Wrong</span>
            </div>

        </div>

        <!-- ACTION BUTTONS -->
        <div>
            <a class="btn" href="/Exam/Review?moduleId=@ViewBag.ModuleId">
                🔍 Review Answers
            </a>

            <a class="btn btn-outline" href="/User/Dashboard">
                ← Back to Dashboard
            </a>
        </div>

    </div>

</div>