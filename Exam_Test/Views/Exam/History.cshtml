@model List<Exam_Test.Models.Result>

@{
    ViewData["Title"] = "My Exam History";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f4f6ff;
        color: #111827;
    }

    .page {
        max-width: 900px;
        margin: auto;
        padding: 40px 20px;
    }

    .header {
        margin-bottom: 18px;
    }

        .header h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

        .header p {
            font-size: 13px;
            color: #6b7280;
            margin-top: 5px;
        }

    /* CARD */
    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0,0,0,0.04);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: #4f46e5;
        color: white;
    }

    th, td {
        padding: 14px 16px;
        font-size: 13px;
        text-align: left;
    }

    tbody tr {
        border-bottom: 1px solid #e5e7eb;
        transition: 0.2s;
    }

        tbody tr:hover {
            background: #f8f9ff;
        }

    /* BADGES */
    .badge-success {
        background: #dcfce7;
        color: #166534;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 500;
    }

    .badge-danger {
        background: #fee2e2;
        color: #991b1b;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 500;
    }

    .date {
        font-size: 12px;
        color: #6b7280;
    }

</style>

<div class="page">

    <div class="header">
        <h2>📊 My Exam History</h2>
        <p>Track your performance and progress</p>
    </div>

    <div class="card">

        <table>

            <thead>
                <tr>
                    <th>Module</th>
                    <th>Correct</th>
                    <th>Wrong</th>
                    <th>Date</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var r in Model)
                {
                    <tr>
                        <td><b>Module @r.ModuleId</b></td>

                        <td>
                            <span class="badge-success">@r.Correct</span>
                        </td>

                        <td>
                            <span class="badge-danger">@r.Wrong</span>
                        </td>

                        <td class="date">
                            @r.ExamDate
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>