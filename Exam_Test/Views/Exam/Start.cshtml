@model List<Exam_Test.Models.Question>

@{
    ViewData["Title"] = "Module Exam";
}

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", Roboto, Arial, sans-serif;
        background: #f4f6ff;
        color: #111827;
    }

    .page {
        max-width: 900px;
        margin: auto;
        padding: 40px 20px;
    }

    .header {
        margin-bottom: 18px;
    }

        .header h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 0;
        }

        .header p {
            font-size: 13px;
            color: #6b7280;
            margin-top: 5px;
        }

    /* QUESTION CARD */
    .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 14px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.04);
    }

    .question {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .image img {
        max-width: 220px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        margin: 10px 0;
    }

    /* OPTIONS */
    .option {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        margin: 6px 0;
        cursor: pointer;
        transition: 0.2s;
        font-size: 13px;
    }

        .option:hover {
            background: #f8f9ff;
            border-color: #c7d2fe;
        }

    input[type="radio"] {
        accent-color: #4f46e5;
        cursor: pointer;
    }

    /* SUBMIT BUTTON */
    .btn {
        display: inline-block;
        margin-top: 20px;
        padding: 12px 18px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 500;
        border: none;
        background: #4f46e5;
        color: #fff;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn:hover {
            background: #3730a3;
        }

</style>

<div class="page">

    <div class="header">
        <h2>📝 Module Exam</h2>
        <p>Choose the correct answers carefully before submitting</p>
    </div>

    <form method="post" action="/Exam/Submit">

        <input type="hidden" name="moduleId" value="@ViewBag.ModuleId" />

        @foreach (var q in Model)
        {
            <div class="card">

                <div class="question">
                    @q.QuestionText
                </div>

                @if (q.ImagePath != null)
                {
                    <div class="image">
                        <img src="~/images/@q.ImagePath" />
                    </div>
                }

                <label class="option">
                    <input type="radio" name="answers[@q.Id]" value="A" />
                    @q.OptionA
                </label>

                <label class="option">
                    <input type="radio" name="answers[@q.Id]" value="B" />
                    @q.OptionB
                </label>

                <label class="option">
                    <input type="radio" name="answers[@q.Id]" value="C" />
                    @q.OptionC
                </label>

                <label class="option">
                    <input type="radio" name="answers[@q.Id]" value="D" />
                    @q.OptionD
                </label>

            </div>
        }

        <button type="submit" class="btn">
            🚀 Submit Exam
        </button>

    </form>

</div>